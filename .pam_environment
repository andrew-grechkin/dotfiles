# vim: syntax=conf foldmethod=marker

# => defaults ---------------------------------------------------------------------------------------------------- {{{1

EDITOR              DEFAULT=vim
PAGER               DEFAULT=less
VISUAL              DEFAULT=vim

# => xdg --------------------------------------------------------------------------------------------------------- {{{1

XDG_CACHE_HOME      DEFAULT="@{HOME}/.cache"
XDG_CONFIG_HOME     DEFAULT="@{HOME}/.config"
XDG_DATA_HOME       DEFAULT="@{HOME}/.local/share"

# => shell ------------------------------------------------------------------------------------------------------- {{{1

ZDOTDIR             DEFAULT="${XDG_CONFIG_HOME}/zsh"
FUSE3_P7ZIP_FORMATS DEFAULT="Iso:Udf:*:APM:GPT"

# => wine -------------------------------------------------------------------------------------------------------- {{{1

WINEPREFIX          DEFAULT="${XDG_CACHE_HOME}/wine/default-x64"
WINEARCH            DEFAULT=win64

# => X11 settings ------------------------------------------------------------------------------------------------ {{{1

GTK_RC_FILES        DEFAULT="${XDG_CONFIG_HOME}/x11/gtk1rc"
GTK2_RC_FILES       DEFAULT="${XDG_CONFIG_HOME}/x11/gtk2rc"
#XINITRC             DEFAULT="${XDG_CONFIG_HOME}/.config/x11/xinitrc"
#XSERVERRC           DEFAULT="${XDG_CONFIG_HOME}/x11/xserverrc"

### this might break lightdm
XAUTHORITY          DEFAULT="${XDG_RUNTIME_DIR}/Xauthority"
#ICEAUTHORITY        DEFAULT="${XDG_RUNTIME_DIR}/ICEauthority"

# => kde --------------------------------------------------------------------------------------------------------- {{{1

#KDEWM               DEFAULT="/usr/bin/i3"
KDEHOME             DEFAULT="${XDG_CONFIG_HOME}/kde"

# => misc -------------------------------------------------------------------------------------------------------- {{{1

GROFF_TMPDIR        DEFAULT="/tmp"

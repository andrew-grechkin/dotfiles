# vim: syntax=conf foldmethod=marker

# => defaults ---------------------------------------------------------------------------------------------------- {{{1

EDITOR              DEFAULT=vim
PAGER               DEFAULT=less
VISUAL              DEFAULT=vim

# => xdg --------------------------------------------------------------------------------------------------------- {{{1

XDG_CACHE_HOME      DEFAULT="@{HOME}/.cache"
XDG_CONFIG_HOME     DEFAULT="@{HOME}/.config"
XDG_DATA_HOME       DEFAULT="@{HOME}/.local/share"

# => wine -------------------------------------------------------------------------------------------------------- {{{1

WINEPREFIX          DEFAULT="@{HOME}/.cache/wine/default-x32"
WINEARCH            DEFAULT=win32

# => shell ------------------------------------------------------------------------------------------------------- {{{1

ZDOTDIR             DEFAULT="${XDG_CONFIG_HOME}/zsh"

# => X11 settings ------------------------------------------------------------------------------------------------ {{{1

GTK_RC_FILES        DEFAULT="@{HOME}/.config/x11/gtk1rc"
GTK2_RC_FILES       DEFAULT="@{HOME}/.config/x11/gtk2rc"
#XINITRC             DEFAULT="@{HOME}/.config/x11/xinitrc"
#XSERVERRC           DEFAULT="@{HOME}/.config/x11/xserverrc"

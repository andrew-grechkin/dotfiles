# ensure in git repo
[group('helpers'), private, no-cd]
@in-git-repo:
    git rev-parse HEAD &>/dev/null

# login to docker repository
[group('helpers'), no-cd]
@login-docker user:
    #!/usr/bin/env -S bash -Eeuo pipefail
    echo "$GITLAB_TOKEN" | docker login 'registry.gitlab.com' -u "$user" --password-stdin

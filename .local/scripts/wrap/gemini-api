# => http --------------------------------------------------------------------------------------------------------- {{{1

[private, no-cd]
[group('http')]
http-request method uri *argv:
    #!/usr/bin/env -S bash -Eeuo pipefail
    uri='{{uri}}' && [[ "$uri" == /* ]] && uri="$GOOGLE_HOST$GOOGLE_API${uri#${GOOGLE_API}}"
    argv=({{argv}})
    '{{this}}' generic-http-request '{{method}}' "$uri" \
        x-goog-api-key:"${GEMINI_API_KEY:-$(credp "$GOOGLE_ACCOUNT@$GOOGLE_HOST")}" "${argv[@]@Q}"

[private, no-cd]
[group('http')]
http-stream method uri *argv:
    #!/usr/bin/env -S bash -Eeuo pipefail
    uri='{{uri}}' && [[ "$uri" == /* ]] && uri="$GOOGLE_HOST$GOOGLE_API${uri#${GOOGLE_API}}"
    argv=({{argv}})
    '{{this}}' streaming-http-request '{{method}}' "$uri" \
        x-goog-api-key:"${GEMINI_API_KEY:-$(credp "$GOOGLE_ACCOUNT@$GOOGLE_HOST")}" "${argv[@]@Q}"

[private, no-cd]
[group('http')]
http-request-body method uri *argv:
    #!/usr/bin/env -S bash -Eeuo pipefail
    argv=({{argv}})
    '{{this}}' http-request '{{method}}' '{{uri}}' --no-ignore-stdin "${argv[@]@Q}"

[private, no-cd]
[group('http')]
http-request-all method uri *argv:
    #!/usr/bin/env -S bash -Eeuo pipefail
    uri='{{uri}}' && [[ "$uri" == /* ]] && uri="$GOOGLE_HOST$GOOGLE_API${uri#${GOOGLE_API}}"
    argv=({{argv}})
    req=(
        '{{this}}' generic-http-request '{{method}}' "$uri"
        x-goog-api-key:"${GEMINI_API_KEY:-$(credp "$GOOGLE_ACCOUNT@$GOOGLE_HOST")}" "${argv[@]@Q}"
    )
    while res=$("${req[@]}" ${page_token:+pageToken==$page_token}); do
        jq -c <<< "$res"
        page_token=$(jq -c '.nextPageToken // empty' <<< "$res")
        [[ -n "$page_token" ]] || break
    done

#!/usr/bin/env -S perl

# ABSTRACT: rebase paths from a source to a destination directory

use v5.36;
use English               qw(-no_match_vars);
use File::Spec::Functions qw(abs2rel rel2abs);

die "invalid args: @ARGV\n" if @ARGV > 2;
my @to   = ($ARGV[1] || ());
my @from = ($ARGV[0] || ());
local @ARGV = ();

my $separator = $0 =~ m/0$/ ? "\0" : "\n";

local $INPUT_RECORD_SEPARATOR  = $separator;
local $OUTPUT_RECORD_SEPARATOR = $separator;

while (<<>>) {
    chomp;
    print abs2rel(rel2abs($_, @from), @to);
}

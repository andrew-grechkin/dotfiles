            --footer="A-i:inspect enter:view | A-b:browse A-p:preview"
            --preview="${api@Q} get-service ${project@Q} {3} | ${this@Q} json::pretty -Cf {3}"
            --prompt="$HARNESS_ORG_ID | services[$project] > "

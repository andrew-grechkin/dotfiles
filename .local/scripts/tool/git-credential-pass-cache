#!/usr/bin/env bash

set -Eeuo pipefail

# @meta combine-shorts
# @meta require-tools pass
# @meta version 1.0.0

# @describe ABSTRACT:
#   Git credential helper with persistent storage in `pass` password manager
#
# SYNOPSIS:
#   git-credential-pass-cache store <<< $'protocol=https\nhost=gitlab.com\npassword=secret'
#   git-credential-pass-cache get   <<< $'protocol=https\nhost=gitlab.com'
#   git-credential-pass-cache erase <<< $'protocol=https\nhost=gitlab.com'
#
# DESCRIPTION:
#   Works like git-credential-cache/git-credential-file but uses `pass` for persistent storage, allowing
#   credentials to survive system reboots and keeping them encrypted at rest. All credential attributes stored as is.
#   This is useful for storing refresh tokens since some credential helpers (like `osxkeychain`)
#   only store passwords, leading to repetitive re-authentication requests when OAuth2 is used.
#
#   Files are stored in the `pass` storage as "git-credential-pass-cache/$protocol/$host/$username"

[[ -x "$(command -v argc)" ]] || {
    echo "'argc' helper command is required, install from https://github.com/sigoden/argc" >&2
    exit 2
}

# shellcheck disable=SC2016
readonly PASS_PATH_TEMPLATE='git-credential-pass-cache/$protocol/$host/$username'

# read, cache and process STDIN
function _read_stdin() {
    input="$(</dev/stdin)"

    # parse key=value lines to global variables
    while read -r line; do
        [[ "$line" =~ ^[_[:lower:]][_[:lower:][:digit:]]*= ]] && declare -g -- "$line"
    done <<< "$input"

    if [[ -z "${protocol:-}" || -z "${host:-}" ]]; then
        echo "continue=1"
        exit 0
    fi

    if [[ -z "${username:-}" ]]; then
        username="$USER"
        input+=$'\nusername='"$username"  # append defaulted username to stored credentials
    fi
}

# @cmd
# @describe
# Retrieve credentials from `pass`
#
# DESCRIPTION:
#   Reads credential query from STDIN and searches for matching credentials in `pass`
#   Prints the found credentials to STDOUT
#   Tries usernames in priority order: specified username, $USER, oauth2
function get() {
    _read_stdin

    local credentials users=("$USER" "oauth2")
    [[ "${users[0]}" != "$username" ]] && users=("$username" "${users[@]}")

    for username in "${users[@]}"; do
        if credentials=$(pass show "${PASS_PATH_TEMPLATE@P}" 2>/dev/null) && [[ -n "$credentials" ]]; then
            echo "$credentials"
            exit 0
        fi
    done

    echo "continue=1"
}

# @cmd
# @describe
# Store credentials to `pass`
#
# DESCRIPTION:
#   Reads credential data from STDIN and stores it encrypted in `pass`
#   Stores all attributes including password, token, expiration time and OAuth2 refresh token
function store() {
    _read_stdin

    pass insert -mf "${PASS_PATH_TEMPLATE@P}" >/dev/null <<< "$input"
}

# @cmd
# @describe
# Erase credentials from `pass`
#
# DESCRIPTION:
#   Reads credential query from STDIN and removes matching credentials from `pass`
#   Silently ignores non-existent credentials
function erase() {
    _read_stdin

    pass rm -f "${PASS_PATH_TEMPLATE@P}" >&2 || true # ignore non-existing files but write message to STDERR
}

eval "$(argc --argc-eval "$0" "$@")"

#!/usr/bin/env bash

set -Eeuo pipefail

# A git credential helper that stores credentials persistently in pass
# Works like git-credential-cache but uses pass for persistent storage
# Stores all credential attributes (including OAuth refresh tokens if provided)
# Usage: git-credential-pass-cache <operation>
# Operations: get, store, erase

# Read credential attributes from stdin
read_attributes() {
    local -A attrs
    while IFS='=' read -r key value; do
        [[ -z "$key" ]] && break
        attrs["$key"]="$value"
    done
    declare -p attrs
}

# Build pass path from credential attributes
build_pass_path() {
    local -n attrs_ref="$1"
    local protocol="${attrs_ref[protocol]:-}"
    local host="${attrs_ref[host]:-}"
    local username="${attrs_ref[username]:-${USER}}"

    if [[ -z "$protocol" || -z "$host" ]]; then
        echo "Error: protocol and host are required" >&2
        return 1
    fi

    echo "git-credential-pass-cache/$protocol/$host/$username"
}

# Get operation: retrieve credentials from pass
do_get() {
    eval "$(read_attributes)"

    local protocol="${attrs[protocol]:-}"
    local host="${attrs[host]:-}"
    local username="${attrs[username]:-}"

    if [[ -z "$protocol" || -z "$host" ]]; then
        echo "Error: protocol and host are required" >&2
        exit 1
    fi

    # Try exact username first if provided
    if [[ -n "$username" ]]; then
        local pass_path="git-credential-pass-cache/$protocol/$host/$username"
        if pass show "$pass_path" &>/dev/null 2>&1; then
            pass show "$pass_path"
            exit 0
        fi
    fi

    # No username provided or exact match failed - try common OAuth usernames
    local base_path="git-credential-pass-cache/$protocol/$host"
    for user in "oauth2" "$USER"; do
        local pass_path="$base_path/$user"
        if pass show "$pass_path" &>/dev/null 2>&1; then
            pass show "$pass_path"
            exit 0
        fi
    done

    # Nothing found
    exit 0
}

# Store operation: save credentials to pass
do_store() {
    eval "$(read_attributes)"
    local pass_path
    pass_path=$(build_pass_path attrs) || exit 1

    # Build the credential data to store
    local -a data_lines=()

    for key in "${!attrs[@]}"; do
        data_lines+=("$key=${attrs[$key]}")
    done

    # Store in pass
    printf '%s\n' "${data_lines[@]}" | pass insert -m -f "$pass_path" &>/dev/null
}

# Erase operation: remove credentials from pass
do_erase() {
    eval "$(read_attributes)"
    local pass_path
    pass_path=$(build_pass_path attrs) || exit 1

    if pass show "$pass_path" &>/dev/null; then
        pass rm -f "$pass_path" &>/dev/null
    fi
}

# Main
case "${1:-}" in
    get)
        do_get
        ;;
    store)
        do_store
        ;;
    erase)
        do_erase
        ;;
    *)
        echo "Usage: git-credential-pass-cache <get|store|erase>" >&2
        exit 1
        ;;
esac

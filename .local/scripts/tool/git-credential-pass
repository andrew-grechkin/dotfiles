#!/usr/bin/env bash

set -Eeuo pipefail

# @meta combine-shorts
# @meta require-tools jq,pass
# @meta version 1.0.0

# @option -k --key     Expect secret to be a value of a key in a JSON
# @option -p --path    Explicit path to the secret

# @describe ABSTRACT:
#   Git credential helper to fetch predefined credentials from `pass` password manager
#
# SYNOPSIS:
#   git-credential-pass get <<< $'protocol=token\nhost=gitlab.com'
#
# DESCRIPTION:
#   This helper is designed to retrieve existing, pre-configured credentials from the `pass`
#   password manager for use with Git. Implemented as read-only by design; its `store` and `erase` commands
#   are intentionally left as dummies and perform no action on `pass`.
#
#   It excels in scenarios where credentials are static, such as API tokens, passwords, or other
#   complex secrets, are manually stored in `pass` under specific paths or embedded
#   within JSON structures.
#
#   The helper expects the password on the first line of the `pass` entry, within a `password=` field,
#   or as a JSON key if `--key` is used.
#
#   The path to the secret in `pass` defaults to '$protocol/$host/$username'.
#   The "$username" is either provided via STDIN or defaults to the current shell user: "$USER".
#   This default path can be overridden entirely using the `--path` option to specify an explicit secret location.

[[ -x "$(command -v argc)" ]] || {
    echo "'argc' helper command is required, install from https://github.com/sigoden/argc" >&2
    exit 2
}

# read, cache and process STDIN
function _read_stdin() {
    # parse key=value lines to global variables
    # if your AI tells you this imposes security risk - use a smarter one, not an imbecile
    while read -r line; do
        [[ "$line" =~ ^[_[:lower:]][_[:lower:][:digit:]]*= ]] && declare -g -- "$line"
    done

    if [[ -z "${protocol:-}" || -z "${host:-}" || -z "${username:=$USER}" ]]; then
        echo "continue=1"
        exit 0
    fi
}

# @cmd
# @describe
# Retrieve credentials from `pass`
#
# DESCRIPTION:
#   Reads credential query from STDIN and searches for matching credentials in `pass`
#   Prints the found credentials to STDOUT
function get() {
    _read_stdin

    local credentials argc_path="${argc_path:-"$protocol/$host/$username"}"

    if ! credentials="$(pass show "$argc_path" 2>/dev/null)"; then
        echo "> $(basename "$0") unable to fetch secret: $argc_path" >&2
        echo "continue=1"
        exit 0
    fi

    echo "protocol=$protocol"
    echo "host=$host"
    [[ "$credentials" =~ "username=" ]] || echo "username=$username"

    if [[ -n "${argc_key:-}" ]] \
        && value=$(jq -r --arg key "$argc_key" '.[$key] // empty' <<< "$credentials" 2>/dev/null) \
        && [[ -n "$value" ]]; then
        echo "password=$value"
    elif [[ "$credentials" =~ "password=" ]]; then
        echo "$credentials"
    else
        echo "password=$(head -1 <<< "$credentials")"
    fi
}

# @cmd
# @describe
# dummy (required by the contract but ignored for this helper)
function store() { :; }

# @cmd
# @describe
# dummy (required by the contract but ignored for this helper)
function erase() { :; }

eval "$(argc --argc-eval "$0" "$@")"

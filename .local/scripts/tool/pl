#!/usr/bin/env -S just --one --justfile

# https://just.systems/man/en/

set export := true
export this := justfile()

[private, no-cd]
@default:
    "$this" --list

# install modules from a cpanfile in current dir included in specified features
[no-cd, positional-arguments]
install-features *feature:
    #!/usr/bin/env -S bash -Eeuo pipefail

    args=("${@/#/--with-feature=}" )

    [[ -r cpanfile ]] || {
        cd "$HOME/.local/lib" || exit 2
    }

    nice cpanm -nq --installdeps . --with-develop "${args[@]}" 2>&1 \
        | grep --line-buffered -Ev 'LIBARCHIVE[.]xattr[.]com[.](apple|macromates)' || true

# install prereqs for a given .pl/.pm files
[no-cd, positional-arguments]
install-prereqs *file:
    #!/usr/bin/env -S bash -Eeuo pipefail

    perl -lnE 'print m/\s* use \s+ ([[:alpha:]:]+)/xx if m/^\s* use \s+ [[:upper:]]/xx' "$@" \
        | sort \
        | uniq \
        | xargs -r cpanm -nq

# install modules from cpanfile
[no-cd]
install cpanfile='':
    #!/usr/bin/env -S bash -Eeuo pipefail

    if [[ -z "$cpanfile" ]]; then
        cpanfile="$HOME/.local/lib/cpanfile"
    fi

    nice cpanm -nq --installdeps "$(dirname "$cpanfile")" 2>&1 \
        | grep --line-buffered -Ev 'LIBARCHIVE[.]xattr[.]com[.](apple|macromates)' || true

# install all modules from cpanfile including features
[no-cd]
install-all cpanfile='':
    #!/usr/bin/env -S bash -Eeuo pipefail

    if [[ -z "$cpanfile" ]]; then
        cpanfile="$HOME/.local/lib/cpanfile"
    fi

    nice cpanm -nq --installdeps "$(dirname "$cpanfile")" --with-develop --with-all-features 2>&1 \
        | grep --line-buffered -Ev 'LIBARCHIVE[.]xattr[.]com[.](apple|macromates)' || true

# install modules modules from cpanfile including devel
[no-cd]
install-devel cpanfile='':
    #!/usr/bin/env -S bash -Eeuo pipefail

    if [[ -z "$cpanfile" ]]; then
        cpanfile="$HOME/.local/lib/cpanfile"
    fi

    nice cpanm -nq --installdeps "$(dirname "$cpanfile")" --with-develop 2>&1 \
        | grep --line-buffered -Ev 'LIBARCHIVE[.]xattr[.]com[.](apple|macromates)' || true


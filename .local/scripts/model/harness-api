#!/usr/bin/env -S just --one --justfile

# ABSTRACT: wrapper around Harness API

# https://just.systems/man/en/
# https://apidocs.harness.io/

mod http "~/.local/lib/just/http"

set export
export jq := require('jq')
export this := justfile()

export HARNESS_ACCOUNT := env('HARNESS_ACCOUNT')
export HARNESS_API := '/ng/api'
export HARNESS_HOST := env('HARNESS_HOST', 'app.harness.io')
export HARNESS_ORG_ID := env('HARNESS_ORG_ID', '')
export HARNESS_PER_PAGE := env('HARNESS_PER_PAGE', '100')

# => default ------------------------------------------------------------------------------------------------------ {{{1

[private, no-cd]
@default:
    "$this" --list

# => groups ------------------------------------------------------------------------------------------------------- {{{1

# https://apidocs.harness.io/user-group/getusergrouplist
# list groups
[group('groups'), no-cd]
list-groups:
    #!/usr/bin/env -S bash -Eeuo pipefail

    mem_args=(-l list-groups-$HARNESS_ORG_ID.jsonl -t 60min -- cat)
    if ! memoize -c "${mem_args[@]}"; then
        uri="/ng/api/user-groups"
        page0="$("$this" http-request GET "$uri" pageIndex==0 pageSize==2000 filterType==INCLUDE_CHILD_SCOPE_GROUPS)"
        total=$(jq -r '.data.totalPages // 0' <<< "$page0")
        {
            jq -c '.data.content[]' <<< "$page0"
            for (( i=1; i<=total; ++i )); do
                "$this" http-request GET "$uri" pageIndex==$i pageSize==2000 filterType==INCLUDE_CHILD_SCOPE_GROUPS | jq -c '.data.content[]'
            done
        } | memoize "${mem_args[@]}"
    fi | jq -n '[inputs]'

# https://apidocs.harness.io/user-group/getusergrouplist
# list account groups
[group('groups'), no-cd]
list-account-groups:
    #!/usr/bin/env -S bash -Eeuo pipefail

    mem_args=(-l list-account-groups.jsonl -t 60min -- cat)
    if ! memoize -c "${mem_args[@]}"; then
        unset HARNESS_ORG_ID
        uri="/ng/api/user-groups"
        page0="$("$this" http-request GET "$uri" pageIndex==0 pageSize==2000)"
        total=$(jq -r '.data.totalPages // 0' <<< "$page0")
        {
            jq -c '.data.content[]' <<< "$page0"
            for (( i=1; i<=total; ++i )); do
                "$this" http-request GET "$uri" pageIndex==$i pageSize==2000 | jq -c '.data.content[]'
            done
        } | memoize "${mem_args[@]}"
    fi | jq -n '[inputs]'

# get group
[group('groups'), no-cd]
get-group name:
    #!/usr/bin/env -S bash -Eeuo pipefail
    "$this" list-groups | jq --arg name "$name" '.[] | select(.name == $name)'

# get group by id
[group('groups'), no-cd]
get-group-by-id id:
    #!/usr/bin/env -S bash -Eeuo pipefail
    "$this" http-request GET "/ng/api/user-groups/$id"

# list users in a group by id
[group('groups'), no-cd]
list-users-by-id id:
    #!/usr/bin/env -S bash -Eeuo pipefail
    "$this" http-request POST "/ng/api/user-groups/$id/users" parentFilter=NO_PARENT_SCOPES

# => pipelines ---------------------------------------------------------------------------------------------------- {{{1

# https://apidocs.harness.io/pipelines/list-pipelines
# list pipelines
[group('pipelines'), no-cd]
list-pipelines project:
    #!/usr/bin/env -S bash -Eeuo pipefail
    id=$("$this" get-project-id "$project")
    args=()
    "$this" http-request GET "$HARNESS_HOST/v1/orgs/$HARNESS_ORG_ID/projects/$id/pipelines" "${args[@]}"

# https://apidocs.harness.io/pipelines/get-pipeline
# get pipeline
[group('pipelines'), no-cd]
get-pipeline project id:
    #!/usr/bin/env -S bash -Eeuo pipefail
    project_id=$("$this" get-project-id "$project")
    args=()
    "$this" http-request GET "$HARNESS_HOST/v1/orgs/$HARNESS_ORG_ID/projects/$project_id/pipelines/$id" "${args[@]}"

# https://apidocs.harness.io/pipeline-execution-details/getlistofexecutions
# list pipeline executions
[group('pipelines'), no-cd]
list-executions project pipeline_id='':
    #!/usr/bin/env -S bash -Eeuo pipefail
    args=(
        "projectIdentifier==$("$this" get-project-id "$project")"
        # "searchTerm": "string",
        # "status": "Running",
    )
    [[ -n "$pipeline_id" ]] && args+=("pipelineIdentifier==$pipeline_id")

    "$this" http-request POST "$HARNESS_HOST/pipeline/api/pipelines/execution/summary" "${args[@]}" \
        |jq '.data.content'

# https://apidocs.harness.io/pipeline-execution-details/getexecutiondetailv2
# get pipeline execution
[group('pipelines'), no-cd]
get-execution project execution_id:
    #!/usr/bin/env -S bash -Eeuo pipefail
    args=(
        "projectIdentifier==$("$this" get-project-id "$project")"
    )
    "$this" http-request GET "$HARNESS_HOST/pipeline/api/pipelines/execution/v2/$execution_id" "${args[@]}" \
        | jq '.data.pipelineExecutionSummary'

# https://apidocs.harness.io/pipeline-execution-details/getinputsetyamlv2
# https://apidocs.harness.io/pipeline-execution/rerun-pipeline
# retry pipeline execution
[group('pipelines'), no-cd]
retry-execution project pipeline_id execution_id:
    #!/usr/bin/env -S bash -Eeuo pipefail
    project_id=$("$this" get-project-id "$project")
    args=(
        "projectIdentifier==$("$this" get-project-id "$project")"
    )
    if payload=$("$this" http-request GET "$HARNESS_HOST/pipeline/api/pipelines/execution/$execution_id/inputsetV2" "${args[@]}" \
        | jq '{inputs_yaml: .data.inputSetYaml}'); then
        "$this" http-request POST "$HARNESS_HOST/v1/orgs/$HARNESS_ORG_ID/projects/$project_id/pipelines/$pipeline_id/execute/rerun/$execution_id" --no-ignore-stdin "${args[@]}" <<< "$payload"
    fi

# https://apidocs.harness.io/pipeline-execute/puthandleinterrupt
# cancel pipeline execution
[group('pipelines'), no-cd]
cancel-execution project pipeline_id execution_id:
    #!/usr/bin/env -S bash -Eeuo pipefail
    args=(
        "projectIdentifier==$("$this" get-project-id "$project")"
        "interruptType==UserMarkedFailure"
    )
    "$this" http-request PUT "$HARNESS_HOST/pipeline/api/pipeline/execute/interrupt/$execution_id" "${args[@]}"

# => projects ----------------------------------------------------------------------------------------------------- {{{1

# https://apidocs.harness.io/project/getprojectlist
# list projects
[group('projects'), no-cd]
list-projects:
    #!/usr/bin/env -S bash -Eeuo pipefail

    mem_args=(-l list-projects-$HARNESS_ORG_ID.jsonl -t 60min -- cat)
    if ! memoize -c "${mem_args[@]}"; then
        args=('/ng/api/projects' pageSize==2000)
        page0=$("$this" http-request GET "${args[@]}" pageIndex==0)
        total=$(jq -r '.data.totalPages // 0' <<< "$page0")
        {
            jq -c '.data.content[]' <<< "$page0"
            for (( i=1; i<=total; ++i )); do
                "$this" http-request GET "${args[@]}" "pageIndex==$i" | jq -c '.data.content[]'
            done
        } | jq -nc '[inputs]' | memoize "${mem_args[@]}"
    fi

# get project id by name
[group('project'), no-cd]
get-project-id name:
    #!/usr/bin/env -S bash -Eeuo pipefail
    memoize -- "$this" http-request GET '/ng/api/projects' "searchTerm==$name" \
        | jq -r --arg name "$name" '.data.content[] | select(.project.name == $name) | .project.identifier'

# create project
[group('project'), no-cd]
create-project name:
    #!/usr/bin/env -S bash -Eeuo pipefail
    name="${name@L}"
    body=$(jq -cnR --arg n "$name" --arg i "${name//-/_}" --arg o "$HARNESS_ORG_ID" ' {
    project: {
        identifier: $i,
        name: $n,
        orgIdentifier: $o
    } }'
    "$this" POST '/ng/api/projects' --raw "$body"

    # "${http_cmd[@]::${#http_cmd[@]}-1}" -XPOST "$ha_url/ng/api/file-store$HA_DEFQ&projectIdentifier=${1//-/_}" \
        #   -H 'Content-Type: multipart/form-data' \
        #   -F identifier=services \
        #   -F name=services \
        #   -F type=FOLDER \
        #   -F parentIdentifier=Root

# get project
[group('project'), no-cd]
get-project name:
    #!/usr/bin/env -S bash -Eeuo pipefail
    id=$("$this" get-project-id "$name")
    "$this" http-request GET "/ng/api/projects/$id"

# delete project
[group('projects'), no-cd]
delete-project name:
    #!/usr/bin/env -S bash -Eeuo pipefail
    id=$("$this" get-project-id "$name")
    "$this" http-request DELETE "/ng/api/projects/$id"

# https://apidocs.harness.io/serviceoverrides/getserviceoverrides
# list service overrides
[group('projects'), no-cd]
list-overrides name type='ENV_SERVICE_OVERRIDE':
    #!/usr/bin/env -S bash -Eeuo pipefail
    id=$("$this" get-project-id "$name")
    memoize -t 60min -- "$this" http-request POST '/ng/api/serviceOverrides/v2/list' \
        "projectIdentifier==$id" "type==$type" --json --raw='null'

# => services ----------------------------------------------------------------------------------------------------- {{{1

# https://apidocs.harness.io/services/getservicelist

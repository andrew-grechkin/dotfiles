# => users -------------------------------------------------------------------------------------------------------- {{{1

# https://apidocs.harness.io/user/getcurrentuserinfo
# get current user
[group('users'), no-cd]
get-current-user:
    #!/usr/bin/env -S bash -Eeuo pipefail
    "$this" http-request GET '/user/currentUser'

# https://apidocs.harness.io/user/getaggregatedusers
# search user
[group('users'), no-cd]
search-user term:
    #!/usr/bin/env -S bash -Eeuo pipefail
    "$this" http-request POST '/user/aggregate' "searchTerm==$term"

# https://apidocs.harness.io/user/addusertousergroups
# add user to a group by id
[group('users'), no-cd]
add-user-to-group user_id group_id:
    #!/usr/bin/env -S bash -Eeuo pipefail
    jq -n --arg group "$group_id" '{"userGroupIdsToAdd": [$group]}' \
        | "$this" http-request PUT "/user/add-user-to-groups/$user_id" --no-ignore-stdin

# make me admin
[group('users'), no-cd]
make-me-admin:
    #!/usr/bin/env -S bash -Eeuo pipefail
    user_id="$(harness-api get-current-user | jq -r ".data.uuid")"
    HARNESS_ORG_ID="" "$this" add-user-to-group "$user_id" "Administrator"

# => http --------------------------------------------------------------------------------------------------------- {{{1

[group('http'), private, no-cd, positional-arguments]
http-request method uri *argv:
    #!/usr/bin/env -S bash -Eeuo pipefail
    shift 2
    [[ "$uri" == /* ]] && uri="$HARNESS_HOST$HARNESS_API${uri#${HARNESS_API}}"
    args=(
        "accept:application/json"
        "harness-account:$HARNESS_ACCOUNT"
        "x-api-key:${HARNESS_API_KEY:-$(credp $HARNESS_HOST)}"
        "accountIdentifier==$HARNESS_ACCOUNT"
        "pageSize==$HARNESS_PER_PAGE"
    )
    [[ -n "${HARNESS_ORG_ID:-}" ]] && args+=("orgIdentifier==$HARNESS_ORG_ID")
    "$this" http::request "$method" "$uri" "${args[@]}" "$@"

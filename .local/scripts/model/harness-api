[group('services'), no-cd]
list-services project:
    #!/usr/bin/env -S bash -Eeuo pipefail
    id=$("$this" get-project-id "$project")
    memoize -t 60min -- "$this" http-request GET '/ng/api/servicesV2' \
        "projectIdentifier==$id" | jq '.data.content'

# https://apidocs.harness.io/services/getservicev2
# get service
[group('services'), no-cd]
get-service project name:
    #!/usr/bin/env -S bash -Eeuo pipefail
    "$this" list-services "$project" \
        | jq -r --arg name "$name" '.[] | select(.service.name == $name)'


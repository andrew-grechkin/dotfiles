#!/usr/bin/env perl

use v5.34;
use autodie;
use open ':locale';
use utf8;
use warnings;
use warnings FATAL => qw(utf8);
use experimental qw(declared_refs refaliasing signatures try);

use Module::Loaded;

use Path::Tiny qw(cwd path);

BEGIN {
    eval {
        require YAML::XS;
        1;
    } or do {
        require JSON::PP;
    };
}

sub main() {
    my @inodes = map {path($_)->stat->ino} @ARGV;

    my %links;
    foreach my $inode (@inodes) {
        my @cmd = (qw(btrfs inspect-internal inode-resolve), $inode, '.');
        chomp (my @links = `@cmd`);
        $links{$inode} = [map {_find_absolute_path($_)} @links];
    }

    if (is_loaded('YAML::XS')) {
        say YAML::XS::Dump(\%links);
    } else {
        say JSON::PP->new->pretty->encode(\%links);
    }

    return 0;
}

sub _find_absolute_path ($volume_path, $path = cwd()->absolute) {
    do {
        my $absolute_path = $path->child($volume_path);
        return $absolute_path->absolute->stringify if $absolute_path->exists;
        $path = $path->parent;
    } until ($path->is_rootdir); ## no critic [ControlStructures::ProhibitPostfixControls]
    return $volume_path;
}

exit main();

__END__

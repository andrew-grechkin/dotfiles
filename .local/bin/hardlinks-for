#!/usr/bin/env perl

use v5.34;
use autodie;
use open ':locale';
use utf8;
use warnings;
use warnings FATAL => qw(utf8);
use experimental qw(declared_refs refaliasing signatures try);

use Path::Tiny qw(cwd path);
use JSON::PP;

use constant {'JSON' => JSON::PP->new->pretty};

sub main() {
    my @inodes = map {path($_)->stat->ino} @ARGV;

    my %links;
    foreach my $inode (@inodes) {
        my @cmd = (qw(btrfs inspect-internal inode-resolve), $inode, '.');
        chomp (my @links = `@cmd`);
        $links{$inode} = [map {_find_absolute_path($_)} @links];
    }

    say JSON()->encode(\%links);

    return 0;
}

sub _find_absolute_path ($volume_path) {
    my $path = cwd()->absolute;
    do {
        my $absolute_path = $path->child($volume_path);
        return $absolute_path->absolute->stringify if $absolute_path->exists;
        $path = $path->parent;
    } until ($path->is_rootdir);
    return $volume_path;
}

exit main();

__END__

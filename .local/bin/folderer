#!/usr/bin/env perl

use v5.28;
use strict;
use warnings;
use autodie qw(:all);
use utf8;
use experimental qw(declared_refs refaliasing signatures);

use Carp;
use Path::Tiny;

my \%state = path('.')->visit(
    sub {
        my ($path, $state) = @_;
        $path->is_file
            and push ($state->{'files'}->@*, $path);
    },
    {recurse => 1},
);

$state{'files'}
    or return;

foreach my $path ($state{'files'}->@*) {
    my $parent = $path->parent;
    $parent->basename =~ m{(\d{4})-(\d{2})}
        and next;

    my $name = $path->basename;
    my ($year, $month, $day) = $name =~ m{\[(\d{4})-(\d{2})-(\d{2})\]};
    $year && $month && $day
        or next;

    my $new_dir = $parent->child("$year-$month");
    $new_dir->mkpath;

    my $new_path = $new_dir->child($name);
    $path->move($new_path);
}

__END__

#!/usr/bin/env perl

use v5.28;
use autodie;
use open ':locale';
use utf8;
use warnings;
use warnings FATAL => qw(utf8);
use experimental qw(unicode_strings declared_refs refaliasing signatures);

use Encode qw(decode);
use Getopt::Long qw(:config auto_version bundling no_ignore_case);
use Path::Tiny;

our $VERSION = 1;

my %options = (
    'APPLY'   => 0,
    'FOLLOW'  => 0,
    'RECURSE' => 0,
);

GetOptions(
    'apply|a'   => \$options{'APPLY'},
    'follow|f'  => \$options{'FOLLOW'},
    'match|m'   => \(my $match),
    'recurse|r' => \$options{'RECURSE'},
) or die ('Unable to process command line options');

$match //= qr{(\d{4}-\d{2})-\d{2}};

my \%state = path('.')->visit(
    sub {
        my ($path, $state) = @_;
        $path->is_file
            or return;

        push ($state->{'files'}->@*, path(decode('UTF-8', $path->stringify, Encode::FB_CROAK)));
    },
    {
        'follow_symlinks' => $options{'FOLLOW'},
        'recurse'         => $options{'RECURSE'},
    },
);

$state{'files'}
    or return;

foreach my $path ($state{'files'}->@*) {
    my $parent = $path->parent;

    # check if already moved
    $parent->basename =~ $match
        and next;

    my $name = $path->basename;
    if ($name =~ $match) {
        $1
            or next;

        my $new_dir = $parent->child($1);
        if ($options{'APPLY'}) {
            $new_dir->exists or do {
                say 'Creating directory: ', $new_dir;
                $new_dir->mkpath;
            };
        }

        my $new_path = $new_dir->child($name);
        say 'Moving: ', join (' -> ', $path, $new_path);
        $options{'APPLY'}
            and $path->move($new_path);
    }
}

__END__

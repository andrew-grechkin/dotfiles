#!/usr/bin/env perl

use v5.28;
use autodie;
use open ':std', 'IO' => ':locale';
use strict;
use utf8;
use warnings;
use experimental qw(declared_refs refaliasing signatures);

use Encode qw(decode);
use Path::Tiny;

my \%state = path('.')->visit(
    sub {
        my ($path, $state) = @_;
        $path->is_file && !-l $path
            or return;

        $path = path(decode('UTF-8', $path->stringify, Encode::FB_CROAK));
        push ($state->{'files'}->@*, $path);
    },
    {
        'recurse'         => 1,
        'follow_symlinks' => 0,
    },
);

$state{'files'}
    or return;

foreach my $path ($state{'files'}->@*) {
    my $parent = $path->parent;
    $parent->basename =~ m{(\d{4})-(\d{2})}
        and next;

    my $name = $path->basename;
    my ($year, $month, $day) = $name =~ m{\[(\d{4})-(\d{2})-(\d{2})\]};
    $year && $month && $day
        or next;

    my $new_dir = $parent->child("$year-$month");
    $new_dir->exists or do {
        say 'Creating directory: ', $new_dir;
        $new_dir->mkpath;
    };

    my $new_path = $new_dir->child($name);
    $path->move($new_path);
}

__END__

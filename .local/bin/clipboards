#!/bin/bash

set -Euo pipefail

if [[ -n "$(command -v xclip)" ]]; then
	echo -n 'Clipboard: "'
	xclip -o -sel c 2>/dev/null
	echo '"'
	echo
	echo -n 'Primary: "'
	xclip -o -sel p 2>/dev/null
	echo '"'
	echo
	echo -n 'Secondary: "'
	echo '"'
	echo
	xclip -o -sel s 2>/dev/null
elif [[ -n "$(command -v xsel)" ]]; then
	echo -n 'Clipboard: "'
	xsel --clipboard --output 2>/dev/null
	echo '"'
	echo
	echo -n 'Primary: "'
	xsel --primary --output 2>/dev/null
	echo '"'
	echo
	echo -n 'Secondary: "'
	xsel --secondary --output 2>/dev/null
	echo '"'
fi

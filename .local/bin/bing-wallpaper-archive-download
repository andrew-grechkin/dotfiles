#!/usr/bin/env perl

# download latest available Bing photo of the day

use v5.28;
use autodie;
use open ':locale';
use utf8;
use warnings;
use warnings FATAL => qw(utf8);
use experimental qw(unicode_strings declared_refs refaliasing signatures);

use Carp;
use English qw(-no_match_vars);
use JSON::PP ();

BEGIN {
    eval {
        require LWP::Simple;
        require Path::Tiny;
        require URI;
        require YAML::Tiny;
    } or do {
        say 'Please install modules: LWP::Simple Path::Tiny YAML::Tiny';
        exit 2;
    };
}

our $VERSION = 1.1;

use constant {
    'URL_BASE'     => 'http://www.bing.com',
    'URL_PATH'     => 'HPImageArchive.aspx',
    'OUTPUT_DIR'   => Path::Tiny::path('.'),
    'MARKETS'      => {map {$_ => undef} qw(de-DE en-AU en-CA en-IN en-NZ en-UK en-US es-ES fr-FR ja-JP zh-CN)},
    'PARAM_FORMAT' => 'format=js',
    'PARAM_SKIP'   => 'idx=',
    'PARAM_LIMIT'  => 'n=',
    'PARAM_MARKET' => 'mkt=',
};

my $json = JSON::PP->new->utf8(1);
$json->boolean_values(0, 1);

foreach my $market (sort keys MARKETS()->%*) {
    for (my ($skip, $limit) = (0, 5); $skip <= 10; $skip += $limit) {
        say 'Skip: ', $skip;
        my $info = _fetch_info($market, $limit, $skip);

        _fetch_images($market, $info->{'images'}->@*);
    }
}

sub _fetch_info ($market, $limit, $skip) {
    my $url = URI->new_abs(URL_PATH(), URL_BASE());
    $url->query_form({
            'format' => 'js',
            'idx'    => $skip,
            'n'      => $limit,
            'mkt'    => $market,
        },
    );
    say 'Archive url: ', $url;

    my $payload = LWP::Simple::get($url)
        or croak("Failed to retrieve $url: $! $@");

    return $json->decode($payload);
}

sub _fetch_images ($market, @descriptors) {
    foreach my $descriptor (@descriptors) {
        my $dir = OUTPUT_DIR()->child($market);
        $dir->mkpath;
        my $title        = $descriptor->{'copyright'}            =~ s{\s+[(] © .* [)]}{}xmsgr || $descriptor->{'title'};
        my $name         = "[$descriptor->{'startdate'}] $title" =~ s{/}{-}xgr;
        my $jpg_filename = $dir->child($name . '.jpg');
        my $yml_filename = $dir->child($name . '.yml');
        $jpg_filename->exists
            and next;

        my $image_url = URL_BASE() . $descriptor->{'url'};
        say 'Fetching: ', $image_url;
        say 'To:       ', $jpg_filename;
        $yml_filename->spew_utf8(YAML::Tiny::Dump($descriptor));

        my $status = LWP::Simple::getstore($image_url, $jpg_filename->stringify);
        if ($status == 200) {
            say 'HTTP Response OK';
            my $size = -s $jpg_filename;
            if ($size > 0) {
                say "Retrieved $size bytes.";
            } elsif ($size == 0) {
                say 'Seems we have retrieved a zero-byte image';
            }
        } else {
            say "HTTP Response: $status";
        }
        sleep 1;
    }

    return;
}

__END__

#!/usr/bin/env perl

use v5.28;
use autodie;
use open ':locale';
use strict;
use utf8;
use warnings;
use experimental qw(declared_refs refaliasing signatures);

use Carp;
use Digest::MD5 qw(md5_hex);
use Digest::SHA qw(sha256_hex);
use Encode qw(decode);
use Getopt::Long qw(:config auto_version bundling no_ignore_case);
use List::Util qw(all);
use Pod::Usage;

use File::Map qw(map_file);
use Path::Tiny;

our $VERSION = 2;

use constant {
    'DEFAULT_MIN_SIZE'      => 1_024,
    'PARTIAL_CHECKSUM_SIZE' => 1 * 1_024 * 1_024,
    'FS_ENCODING'           => 'UTF-8',
};

my %options = (
    'APPLY'    => 0,
    'FOLLOW'   => 0,
    'MIN_SIZE' => DEFAULT_MIN_SIZE(),
    'RECURSE'  => 0,
    'VERBOSE'  => 0,
);

GetOptions(
    'apply|a'    => \$options{'APPLY'},
    'help|h'     => \(my $help),
    'min|m=i'    => \$options{'MIN_SIZE'},
    'follow|f'   => \$options{'FOLLOW'},
    'recurse|r'  => \$options{'RECURSE'},
    'verbose|v+' => \$options{'VERBOSE'},
) or die ('Unable to process command line options');

if ($help) {
    pod2usage(
        -verbose => 99,
        exitval  => 0,
    );
}

@ARGV
    or push (@ARGV, '.');

### Gather files

$options{'VERBOSE'} > 1
    and say {*STDERR} 'Gathering files';

my %by_dev_ino;
my $files_amount = 0;
foreach my $root (@ARGV) {
    path($root)->visit(
        sub {
            my ($path) = @_;

            $path->is_file && !-l $path
                or return;

            my $stat = $path->stat;
            _is_valid_file($path, $stat)
                or return;

            ++$files_amount;
            my \%it = $by_dev_ino{sprintf ('d(%d)i(%d)', $stat->dev, $stat->ino)}[0] //= {'stat' => $stat};
            push ($it{'paths'}->@*, decode('UTF-8', $path->stringify, Encode::FB_CROAK));
        },
        {
            'follow_symlinks' => $options{'FOLLOW'},
            'recurse'         => $options{'RECURSE'},
        },
    );
}

$options{'VERBOSE'} > 1
    and say {*STDERR} 'Gathering files finished: ', $files_amount;

### Regroup files by dev + size

my $by_dev_size = _regroup(
    \%by_dev_ino,
    'new_key' => sub ($, $value, $) {
        return sprintf ('d(%d)s(%d)', $value->{'stat'}->dev, $value->{'stat'}->size);
    },
);

### Prepare order by dev and file size

my @order = sort { ## no critic [BuiltinFunctions::RequireSimpleSortBlock]
    my ($stat_a, $stat_b) = ($by_dev_size->{$a}->[0]{'stat'}, $by_dev_size->{$b}->[0]{'stat'});
    $stat_a->dev <=> $stat_b->dev || $stat_a->size <=> $stat_b->size
} keys $by_dev_size->%*;

### Process every size group

my $counter = 0;
my $amount  = scalar @order;
foreach my $key (@order) {
    $counter++;
    my \@items = $by_dev_size->{$key};
    my $size = $items[0]->{'stat'}->size;

    $options{'VERBOSE'} > 2 || ($options{'VERBOSE'} && @items > 1)
        and say {*STDERR} sprintf ('Processing bucket  (%d/%d/%d) %s', $counter, $amount, scalar @items, $key);

    my $group = {$by_dev_size->%{$key}};
    if (PARTIAL_CHECKSUM_SIZE() < $size) {
        $group = _regroup(
            $group,
            'state' => {
                'counter' => $counter,
                'amount'  => $amount,
            },
            'is_valid' => sub ($, $value, $) {
                $value->@* > 1;
            },
            'new_key' => sub ($key, $value, $) {
                $value->{'partial_checksum'} or do {
                    map_file(my $map, $value->{'paths'}[0]);
                    $value->{'partial_checksum'} = md5_hex(substr ($map, 0, PARTIAL_CHECKSUM_SIZE()));
                };
                return sprintf ('%sp(%s)', $key, $value->{'partial_checksum'});
            },
        );
    }
    $group = _regroup(
        $group,
        'state' => {
            'counter' => $counter,
            'amount'  => $amount,
        },
        'is_valid' => sub ($, $value, $) {
            $value->@* > 1;
        },
        'new_key' => sub ($key, $value, $s) {
            $value->{'checksum'} or do {
                map_file(my $map, $value->{'paths'}[0]);
                $value->{'checksum'} = sha256_hex($map);
            };
            return sprintf ('%sc(%s)', $key, $value->{'checksum'});
        },
    );

    foreach my $key (keys $group->%*) {
        $options{'VERBOSE'} > 1
            and say {*STDERR} sprintf ('Checksum subbucket (%d/%d/%d) %s', $counter, $amount, scalar @items, $key);
        _process_identical_checksums($key, $group->{$key}->@*);
    }
}

sub _is_valid_file ($path, $stat) {
    $stat->size < $options{'MIN_SIZE'}
        and return;
    return 1;
}

sub _regroup ($current, %params) {
    my $state = $params{'state'} // {};
    my %result;
    foreach my $key (keys $current->%*) {
        my $value = $current->{$key};
        $params{'is_valid'} && !$params{'is_valid'}->($key, $value, $state)
            and next;

        foreach my $file ($value->@*) {
            my $new_key = $params{'new_key'}->($key, $file, $state);
            push ($result{$new_key}->@*, $file);
        }
    }

    return \%result;
}

sub _process_identical_checksums ($checksum, @inodes) {
    @inodes > 1 or do {
        say {*STDERR} ('Skipping subbucket ', $checksum) if $options{'VERBOSE'} > 1;
        return;
    };

    @inodes = sort { ## no critic [BuiltinFunctions::ProhibitReverseSortBlock]
        $a->{'stat'}->mtime <=> $b->{'stat'}->mtime
            || $b->{'paths'}->@* <=> $a->{'paths'}->@*
    } @inodes;

    my $main_inode = shift @inodes;
    my $main_path  = $main_inode->{'paths'}[0];
    foreach my $inode (@inodes) {
        _do_hardlink($main_path, path($_)) foreach $inode->{'paths'}->@*;
    }

    return;
}

sub _do_hardlink ($path, $new_path) {
    my $message = join (' <- ', $path, $new_path);
    say 'Hardlinking: ', $message;

    if ($options{'APPLY'}) {
        my $backup = path($new_path . '.hardlinker');
        my $succeed;
        eval {
            $new_path->move($backup);
            $succeed = link ($path, $new_path);
            return $succeed;
        } or do {
            chomp (my $error = $@ || 'zombie error');
            croak("Unable to hardlink files $message: $error");
        };

        $succeed
            and $backup->remove;
    }

    return;
}

__END__

=head1 NAME

hardlinker

=head1 DESCRIPTION

Detect and hardlink all identical files in given folders.

=head1 SYNOPSIS

hardlinker [options] [dir ...]

=head1 OPTIONS

=over 4

=item B<--apply>

Do real changes on file system

=item B<--recurse>

Process subfolders

=item B<--verbose>

Increase verbosity

=item B<--min>

Minimum size of file to process (default: 1024 bytes)

=back

=cut

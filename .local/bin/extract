#!/usr/bin/env bash

set -Eeo pipefail

if [[ -f "$1" ]]; then
	case "$1" in
		*.tar)            tar xf "$1"    ;;
		*.tar.bz2|*.tbz2) tar xjf "$1"   ;;
		*.tar.gz|*.tgz)   tar xzf "$1"   ;;
		*.tar.xz|*.txz)   tar xf "$1"    ;;
		*.tar.zst|*.tzst) unzstd "$1"    ;;
		*.7z)             7z x "$1"      ;;
		*.Z)              uncompress "$1";;
		*.bz2)            bunzip2 "$1"   ;;
		*.deb)            ar x "$1"      ;;
		*.gz)             gunzip "$1"    ;;
		*.rar)            unrar x "$1"   ;;
		*.zip)            unzip "$1"     ;;
		*)                echo "'$1' cannot be extracted via extract()";;
	esac
else
 	echo "'$1' is not a valid file"
fi

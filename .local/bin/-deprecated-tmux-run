#!/bin/bash

# put me in your path before tmux
# and tmux will play nice with your ssh-agent
#	mkdir ~/bin
#	cp tmux ~/bin
#	chmod +x ~/bin/tmux

TMUX_PATH=/usr/bin/tmux
if [ -e "/opt/bin/tmux" ]; then
	TMUX_PATH="/opt/bin/tmux"
fi

if [ -z "$TMUX" ]; then
	if [ -n "$SSH_TTY" ]; then
		if [ -n "$SSH_AUTH_SOCK" ]; then
			ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/auth-sock"
		fi
		export SSH_AUTH_SOCK="$HOME/.ssh/auth-sock"
	fi
	$TMUX_PATH -2 attach "$@" || $TMUX_PATH -2 "$@"
else
	$TMUX_PATH "$@"
fi

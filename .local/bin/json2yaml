#!/usr/bin/env perl

use v5.28;
use strict;
use warnings;

# non core
use JSON::PP;
use Path::Tiny;
use YAML::Tiny;

my $arg = path($ARGV[0])->absolute;

$arg->exists
    or die "File does not exists: $arg";

if ($arg =~ m/.json$/xms) {
    my $file = $arg->parent->child($arg->basename =~ s/.json$/.yaml/xmsr);
    $file->exists
        and die "File already exists: $file";
    my $json = JSON::PP->new;
    $json->boolean_values(0, 1);
    YAML::Tiny->new($json->decode($arg->slurp_utf8))->write($file->absolute);
} elsif ($arg =~ m/.ya?ml$/xms) {
    my $file = $arg->parent->child($arg->basename =~ s/.ya?ml$/.json/xmsr);
    $file->exists
        and die "File already exists: $file";
    my $yaml_decoded = YAML::Tiny->read($arg)->[0];
    my $json = JSON::PP->new;
    $file->spew_utf8($json->pretty->canonical->encode($yaml_decoded));
} else {
    die 'Unknown format';
}

#!/usr/bin/env perl

use v5.28;
use strict;
use warnings;

# non core
use JSON::PP;
use Path::Tiny;
use YAML::Tiny;

my $path = path($ARGV[0])->absolute;

$path->exists
    or die "File does not exists: $path";

if ($path =~ m/.json$/xms) {
    my $file = $path->parent->child($path->basename =~ s/.json$/.yaml/xmsr);
    $file->exists
        and die "File already exists: $file";
    my $json = JSON::PP->new;
    $json->boolean_values(0, 1);
    YAML::Tiny->new($json->decode($path->slurp_utf8))->write($file->absolute);
} elsif ($path =~ m/.ya?ml$/xms) {
    my $file = $path->parent->child($path->basename =~ s/.ya?ml$/.json/xmsr);
    $file->exists
        and die "File already exists: $file";
    my $yaml_decoded = YAML::Tiny->read($path)->[0];
    my $json         = JSON::PP->new;
    $file->spew_utf8($json->pretty->canonical->encode($yaml_decoded));
} else {
    die 'Unknown format';
}

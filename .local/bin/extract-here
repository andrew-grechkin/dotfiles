#!/usr/bin/env perl

use v5.16;
use strict;
use warnings;
use autodie qw(:all);

use Carp;
use Path::Tiny;

## no critic [RegularExpressions::ProhibitComplexRegexes]
use constant {
    'SUPPORTED' => [{
            'suffix' => qr{
                    .tar$ |
                    .tar.bz2$ | .tbz2$ | .tbz$ | .tz2$ |
                    .tar.gz$ | .tgz$ | .taz$ |
                    .tar.lz$ | .tlzip$ |
                    .tar.lzma$ | .tlzma$ | .tlz$ |
                    .tar.lzop$ | .tlzo$ | .tlzop$ |
                    .tar.xz$ | .txz$ |
                    .tar.zst$ | .tzst$
                    .tar.Z$ | .taZ$
                }x,
            'command' => ['tar', 'xaf', \&_get_filename, '--directory', \&_get_basename],
        },
        {
            'suffix'  => qr{.Z$}x,
            'command' => ['uncompress', \&_get_filename],
        },
        {
            'suffix'  => qr{.bz2$}x,
            'command' => ['bunzip2', \&_get_filename],
        },
        {
            'suffix'  => qr{.deb$}x,
            'command' => ['ar', 'x', \&_get_filename],
        },
        {
            'suffix'  => qr{.gz$}x,
            'command' => ['gunzip', \&_get_filename],
        },
        {
            'suffix'  => qr{.cp866.zip$}x,
            'command' => ['unzip', '-O', 'cp866', '-d', \&_get_basename, \&_get_filename],
        },
        {
            'suffix'  => qr{.7z$ | .rar$ | .zip$}x,
            'command' => [
                '7z', 'x', '-y',
                sub {
                    my ($file, $basename, $arc) = @_;
                    return "-o$basename";
                },
                '--',
                \&_get_filename,
            ],
        },
    ],
};

sub extract {
    my ($file, $arc) = @_;
    my $basename = $file->basename($arc->{'suffix'});

    my $extract_path = $file->parent->child($basename);
    if ($extract_path->exists) {
        say {*STDERR} "Skipping file '$file'. Extract path already exists";
        return 0;
    } else {
        $extract_path->mkpath;
    }

    my @command = map {ref $_ eq 'CODE' ? $_->($file, $basename, $arc) : $_} $arc->{'command'}->@*;
    system (@command);

    return 1;
}

sub _get_filename {
    my ($file, $basename, $arc) = @_;
    return $file->stringify;
}

sub _get_basename {
    my ($file, $basename, $arc) = @_;
    return $basename;
}

foreach my $file (map {path($_)} @ARGV) {
    $file->exists
        or next;

    my $processed;
    foreach my $arc (SUPPORTED()->@*) {
        $file =~ m{$arc->{'suffix'}}
            or next;

        $processed = extract($file, $arc);

        last;
    }

    $processed
        or say {*STDERR} "Unable to process file: $file";
}

__END__

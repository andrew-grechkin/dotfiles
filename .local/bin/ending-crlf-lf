#!/usr/bin/env perl
# man: PerlIO

use v5.28;
use autodie;
use open ':std', IN => ':crlf';
use strict;
use utf8;
use warnings FATAL => qw(utf8);

BEGIN {
    # by some kind of a bug open pragma with ':crlf' is not applied to STDIN
    binmode (STDIN, ':crlf');
}

while (<<>>) { ## no critic [Freenode::WhileDiamondDefaultAssignment]
    chomp;
} continue {
    say;
}

__END__

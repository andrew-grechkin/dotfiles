#!/bin/bash

set -Eeuo pipefail

DN=$(dirname "$0")
PATH=$DN:$PATH
COMMIT="$1"

shift

git-in-repo && {
	if [[ -n "$(git rev-parse --verify "$COMMIT^2" 2>/dev/null)" ]]; then
		# git --no-pager show "$COMMIT" "$@"
		# echo
		git --no-pager m-log "$COMMIT"
		echo
		git --no-pager show --first-parent --color=always -b "$COMMIT" "$@"
		# git m-diff "$COMMIT"
	else
		git --no-pager show "$COMMIT" "$@"
	fi
} 2> /dev/null

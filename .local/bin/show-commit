#!/bin/bash

set -Eeuo pipefail

DN=$(dirname "$0")
PATH=$DN:$PATH
COMMIT="$1"

shift

git-in-repo && {
	if [[ -n "$(git rev-parse --verify "$COMMIT^2" 2>/dev/null)" ]]; then
		git show "$COMMIT" "$@"
		echo
		git m-log "$COMMIT"
		echo
		git m-diff "$COMMIT"
	else
		git show "$COMMIT" "$@"
	fi
} 2> /dev/null

#!/usr/bin/env -S perl -nl -00

use v5.28;
use strict;
use warnings;

## no critic [Variables::ProhibitPunctuationVars, Variables::RequireLocalizedPunctuationVars]

BEGIN {
    $\ = undef;
}

s{^\s*|\s*$}{}g;

length && do {
    $. != 0
        and print ' ';
    print;
};

__END__


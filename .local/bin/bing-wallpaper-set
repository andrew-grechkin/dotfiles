#!/usr/bin/env perl

# ABSTRACT: Download latest available Bing photo of the day and set as wallpaper

# Prereqs (Arch): pacman -S feh perl-net-http

use v5.28;
use autodie;
use open ':locale';
use strict;
use utf8;
use warnings;
use experimental qw(declared_refs refaliasing signatures);

use Carp;
use File::Path qw(make_path);
use File::Spec;
use JSON::PP qw(decode_json);
use List::Util qw(shuffle);

use LWP::Simple;

use constant {
    'ARCHIVE_PATH' => 'HPImageArchive.aspx',
    'BASE_URL'     => 'http://www.bing.com',
    'OUTPUT_DIR'   => File::Spec->catfile($ENV{'XDG_RUNTIME_DIR'} || '/tmp', 'bing-wallpaper-set'),
    'MARKETS'      => [qw(de-DE en-AU en-CA en-IN en-NZ en-UK en-US es-ES fr-FR ja-JP zh-CN)],
    'PARAM_FORMAT' => 'format=js',
    'PARAM_SKIP'   => 'idx=',
    'PARAM_LIMIT'  => 'n=',
    'PARAM_MARKET' => 'mkt=',
};

my $market = shuffle MARKETS()->@*;
my $info   = _fetch_info($market);
my $path   = _fetch_image($market, $info->{'images'}[0]);
_set_wallpaper($path);

exit;

# => ------------------------------------------------------------------------------------------------------------- {{{1

sub _fetch_info ($market, $limit = 1, $skip = 0) {
    my $params = '?' . join ( ## no tidy
        '&', PARAM_FORMAT(),
        "${\PARAM_MARKET}${market}",
        "${\PARAM_LIMIT}${limit}",
        "${\PARAM_SKIP}${skip}",
    );

    my $archive_url = join ('/', BASE_URL(), ARCHIVE_PATH()) . $params;
    say 'Archive url: ', $archive_url;

    my $payload = get($archive_url)
        or croak("Failed to retrieve $archive_url: $! $@");

    return decode_json($payload);
}

sub _fetch_image ($market, $descriptor) {
    make_path(OUTPUT_DIR());
    my $jpg_path = File::Spec->catfile(OUTPUT_DIR(), "image-of-the-day-$market.jpg");

    my $image_url = BASE_URL() . $descriptor->{'url'};
    say 'Fetching: ', $image_url;
    say 'To:       ', $jpg_path;

    getstore($image_url, $jpg_path);

    return $jpg_path;
}

sub _set_wallpaper($path) {
    system (qw(feh --no-fehbg --bg-scale), $path) == 0
        or croak('Unable to set wallpaper: ', $path);

    return;
}

__END__

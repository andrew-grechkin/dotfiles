#!/bin/bash

set -Eeuo pipefail

file=$(readlink -f "$1")

case "$1" in
    *.md|*.mkd|*.mdwiki) pandoc -f markdown+smart -t pdf "$file" | zathura - &>/dev/null & ;;
    *) echo 'unknown' ;;
esac
    # *.md|*.mkd|*.mdwiki) pandoc -f markdown+smart -t pdf --pdf-engine pdfroff "$file" | zathura - &>/dev/null & ;;

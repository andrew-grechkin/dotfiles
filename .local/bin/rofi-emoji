#!/bin/bash

set -Eeuo pipefail

PATH="$(dirname "$0"):$PATH"

chosen="$(perl "${HOME}/.local/bin/grep-emoji" | LC_ALL=en_US.utf8 rofi -dmenu -i -p Emoji)"

[ "$chosen" != "" ] || exit

# shellcheck disable=2001
emoji=$(echo "$chosen" | sed "s/ > .*//")

echo -n "$emoji" | clipcopy && notify-send "$emoji copied to clipboard"

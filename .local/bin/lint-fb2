#!/bin/bash

DATETIME=$(date --rfc-3339=ns)

for FILE in "$@"; do
	echo "Linting file: '$FILE'"

	if xmllint --format "${FILE}" > "${FILE}.${DATETIME}.linted" 2>/dev/null; then
		mv -f "${FILE}.${DATETIME}.linted" "${FILE}"
	else
		echo "Wrong file: '$FILE'"
		rm -f "${FILE}.${DATETIME}.linted"
	fi
done

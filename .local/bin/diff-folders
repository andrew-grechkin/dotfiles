#!/usr/bin/env perl

use v5.28;
use autodie;
use open IO => ':raw';
use utf8;
use warnings;
use warnings FATAL => qw(utf8);
use experimental qw(declared_refs refaliasing signatures);

use List::Util qw(all);

# non core
use Mojo::File qw(path);

sub main() {
    @ARGV == 2
        or die "Please provide 2 directories\n";

    my @dirs = map {path($_)} @ARGV;

    my @absent = grep {!$_->stat} @dirs
        and die "Directory absent\n";

    my (\@left_only, \@right_only, \@diff) = _compare(@dirs, map {$_->list_tree({'hidden' => 1})} @dirs);

    if (@left_only) {
        say 'Only in: ', $dirs[0]->to_string;
        say "\t ",       $_ foreach @left_only;
        say '';
    }

    if (@right_only) {
        say 'Only in: ', $dirs[1]->to_string;
        say "\t ",       $_ foreach @right_only;
        say '';
    }

    if (@diff) {
        say 'Differ: ';
        say "\t ", $_ foreach @diff;
    }

    return 0;
}

sub _compare ($lpath, $rpath, $ltree, $rtree) {
    my %lhs = $ltree->grep(sub {!m{[.]git[/]|[@]eaDir[/]}x})
        ->map(sub ($path) {$path->to_rel($lpath)->to_string, $path->lstat})->@*;
    my %rhs = $rtree->grep(sub {!m{[.]git[/]|[@]eaDir[/]}x})
        ->map(sub ($path) {$path->to_rel($rpath)->to_string, $path->lstat})->@*;

    my (%left_only, %right_only, %diff);
    foreach my $path (keys %lhs) {
        if (!exists $rhs{$path}) {
            $left_only{$lpath->child($path)->to_string} = $lhs{$path};
        } elsif ($lhs{$path}->size != $rhs{$path}->size) {
            $diff{$lpath->child($path)->to_string} = delete $rhs{$path};
        } else {
            delete $rhs{$path};
        }
    }
    foreach my $path (keys %rhs) {
        $right_only{$rpath->child($path)->to_string} = $rhs{$path};
    }

    return ([keys %left_only], [keys %right_only], [keys %diff]);
}

exit main();

__END__

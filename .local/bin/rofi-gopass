#!/usr/bin/env bash

set -Eeuo pipefail

DN=$(dirname "$0")
PATH="$DN:$PATH"

function list-gopass-files() {
	shopt -s nullglob globstar

	path_config=$(gopass config 2>/dev/null | grep 'path:')
	#path=${path_config#*"file://"}
	path=${path_config#*"path: "}

	password_files=("$path"/**/*.gpg)
	password_files=("${password_files[@]#*"$path/"}")
	password_files=("${password_files[@]%".gpg"*}")

	# password=$(printf '%s\n' "${password_files[@]}" | rofi -dmenu -i -p gopass: "$@")
	printf '%s\n' "${password_files[@]}"
}

if [[ $# -lt 1 ]]; then
	rofi -modi "Password:${0} --pass,OTP:${0} --otp,Name:${0} --name" -show Password -normal-window
elif [[ $# -lt 2 ]]; then
	list-gopass-files
else
	if [[ "$1" == "--pass" ]]; then
		# gopass --clip is broken for some reason, temporary substitution
		mapfile -t DATA < <(gopass show "$2")
		echo "${DATA[0]}" | xclip -i -sel p -f | xclip -i -sel c &>/dev/null
		notify-send "Password for $2 copied to clipboard" -i dialog-password
		#gopass --clip "$2" | while read -r MESSAGE; do notify-send "$MESSAGE" -i dialog-password; done
	elif [[ "$1" == "--otp" ]]; then
		gopass otp --clip "$2" | while read -r MESSAGE; do notify-send "$MESSAGE" -i dialog-password; done
	elif [[ "$1" == "--name" ]]; then
		USERNAME=$(basename "$2")
		echo -n "$USERNAME" | xclip -i -sel p -f | xclip -i -sel c &>/dev/null && notify-send "Username '$USERNAME' is copied into the clipboard" -i dialog-password
	fi
fi

#!/usr/bin/env perl
# man: PerlIO

use v5.28;
use autodie;
use open ':std', 'OUT' => ':crlf';
use strict;
use utf8;
use warnings;

BEGIN {
    # by some kind of a bug open pragma with ':crlf' is not applied to STDOUT
    binmode (STDOUT, ':raw :crlf');
}

while (<<>>) { ## no critic [Freenode::WhileDiamondDefaultAssignment]
    chomp;
} continue {
    say;
}

__END__

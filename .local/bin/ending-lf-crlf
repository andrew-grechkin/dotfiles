#!/usr/bin/env perl
# man: PerlIO

use v5.28;
use autodie;
use open ':std', 'OUT' => ':crlf :encoding(UTF-8)', 'IN' => ':locale';
use strict;
use utf8;
use warnings;

# by some kind of a bug open pragma with ':crlf' is not applied to STDOUT
binmode (STDOUT, ':pop :crlf :encoding(UTF-8)');

while (defined (my $line = <>)) {
    chomp ($line);
} continue {
    say $line;
}

__END__

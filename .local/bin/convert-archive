#!/usr/bin/env perl

use v5.28;
use strict;
use warnings;
use autodie qw(:all);

use Carp;
use English qw(-no_match_vars);
use Path::Tiny;

use constant {
    'OUTPUT' => {
        'format'    => 'zstd',
        'extention' => '.tzst',
    },
};

foreach my $file (map {path($_)} @ARGV) {
    $file->exists
        or next;
    my $filename = $file->basename;
    my ($name, $extention);
    if ($filename =~ m{(?<name>.*) [.] (?<extention>\w*)$}xms) {
        $name      = $LAST_PAREN_MATCH{'name'}      // '';
        $extention = $LAST_PAREN_MATCH{'extention'} // '';
    }

    my $outfile = $file->parent->child($name . OUTPUT()->{'extention'});
    $outfile->exists
        and die "File already exists: $outfile";

    my $tmp = Path::Tiny->tempdir('convert-archive-XXXXXXXXXX', 'CLEANUP' => 1);

    # extracting
    if ($extention eq 'zip') {

        # use 7z and recode later
        # local $ENV{'LANG'} = 'C';
        # system ('7z', 'x', '-no-utf16', '-y', "-o$tmp", $file);
        # system ("convmv -f cp866 -t utf-8 --notest -r $tmp 2>/dev/null");

        # use unzip-iconv
        # system ('unzip', '-O', 'cp866', '-d', $tmp, $file);

        # use unar with forced encoding
        system ('unar', '-e', '866', '-o', $tmp, $file);
    } elsif ($extention =~ m{[t]?[bz2|gz|xz|z|az]}) {
        system ('unar', '-o', $tmp, $file);
    } else {
        system ('7z', 'x', '-y', "-o$tmp", $file);
    }

    # compressing
    system ('tar', '-I', OUTPUT()->{'format'}, '-cf', $outfile, '-C', $tmp, map {$_->basename} $tmp->children);
}

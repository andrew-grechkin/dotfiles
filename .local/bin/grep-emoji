#!/usr/bin/env perl

use v5.30;

#use autodie qw(:all);
use strict;
use warnings;
use utf8;
use open ':std', ':encoding(UTF-8)';

use English qw(-no_match_vars);

my $filename = "$ENV{HOME}/.local/share/emoji.txt";

open (my $fh, '<:encoding(UTF-8)', $filename)
    or die "Could not open file '$filename' $!";

while (my $line = <$fh>) {
    chomp $line;
    $line or next;
    substr ($line, 0, 1) eq '#' and next;

    if ($line =~ m/[#]\s (?<emoji>\S+) \sE\d+ [.] \d+\s (?<name>.*)/x) {
        say $LAST_PAREN_MATCH{'emoji'}, ' > ', $LAST_PAREN_MATCH{'name'};
    }
}

close ($fh);

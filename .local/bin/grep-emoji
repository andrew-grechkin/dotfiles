#!/usr/bin/env perl

use v5.28;
use autodie;
use open ':std', ':encoding(utf-8-strict)';
use strict;
use utf8;
use warnings;

use English qw(-no_match_vars);

unshift (@ARGV, '/usr/share/unicode/emoji/emoji-test.txt');

while (my $line = <>) {
    chomp $line;
    $line && substr ($line, 0, 1) ne '#'
        or next;

    if ($line =~ m{[#]\s (?<emoji>\S+) \sE\d+ [.] \d+\s (?<name>.*)}x) {
        say $LAST_PAREN_MATCH{'emoji'}, ' > ', $LAST_PAREN_MATCH{'name'};
    }
}

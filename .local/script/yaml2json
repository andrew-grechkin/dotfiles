#!/usr/bin/env perl

use v5.34;
use autodie;
use open 'IO' => ':raw';
use utf8;
use warnings;
use warnings 'FATAL' => qw(utf8);
use experimental qw(signatures try);

use JSON::PP ();

use YAML::XS ();

sub main() {
    my @data;

    if (@ARGV) {
        foreach my $file (@ARGV) {
            -e -r $file
                or die "File does not exists: $file\n";
            push (
                @data,
                do {local $/ = undef; open my $fh, '<', $file; <$fh>}, ## no critic [InputOutput::RequireBriefOpen]
            );
        }
    } else {
        push (@data, do {local $/ = undef; <STDIN>});
    }

    print _convert(@data);

    return 0;
}

my $json = JSON::PP->new->utf8(1);

sub _convert (@data) {
    my $result;

    foreach my $doc (@data) {
        local $YAML::XS::Boolean = 'JSON::PP'; ## no critic [Variables::ProhibitPackageVars]
        try {
            my $section = $json->decode($doc);
            _unjson_keys($section);
            $result .= YAML::XS::Dump($section);
        } catch ($json_error) {
            try {
                my @sections = YAML::XS::Load($doc);
                $result .= $json->pretty->canonical->encode($_) foreach @sections;
            } catch ($yaml_error) {
                warn "Unable to parse file as json: $json_error\n";
                die "Unable to parse file as yaml: $yaml_error\n";
            }
        } ## no critic [CodeLayout::RequireFinalSemicolon]
    }

    return $result;
}

sub _unjson_keys($data) {
    if (ref $data eq 'ARRAY') {
        for (my $i = 0; $i < scalar $data->@*; ++$i) {
            $data->[$i] = _unjson_keys($data->[$i]);
        }
    } elsif (ref $data eq 'HASH') {
        foreach my $key (keys $data->%*) {
            $data->{$key} = _unjson_keys($data->{$key});
        }
    } else {
        try {
            $data = $json->decode($data);
        } catch ($e) {
            # no-op
        };
    }
    return $data;
}

exit main();

__END__

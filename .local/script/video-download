#!/usr/bin/env bash

set -Eeuo pipefail

URL="$1"

HEIGHT="${HEIGHT:-}"

if [[ -z "$HEIGHT" ]]; then
	HEIGHT="${2:-1440}"
fi

[[ "${#URL}" -lt 16 ]] && {
	URL="https://www.youtube.com/watch?v=$URL"
}

OPTIONS=(
	--prefer-free-formats
	--format="bv*[ext=webm][height<=${HEIGHT}]+ba/bv*[ext=mp4][height<=${HEIGHT}]+ba/b"
	--list-formats
	--no-simulate
	--write-info-json
	--write-thumbnail
)

yt-dlp "${OPTIONS[@]}" "$URL"

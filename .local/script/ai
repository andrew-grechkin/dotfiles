#!/usr/bin/env bash

set -Eeuo pipefail

# ABSTRACT: wrapper around gemini/amp/cody to make requests easier from terminal and other programs by providing sane defaults

[[ "${1:-}" == '-y' ]] && { cmd=' -y'; shift; }

if [[ -t 0 && "$#" -eq 0 ]]; then
    echo "Pass a request to AI via argv or stdin" >&2
    exit 1
fi

if [[ -x "$(command -v gemini)" ]]; then
    # gemini is a good example how you should NOT create cli interface
    cmd="gemini${cmd:-}"
    if [[ -t 0 && -t 1 ]]; then
        cmd+=" -i '$*'"
    else
        [[ -t 0 ]] || cmd="cat | $cmd"
        [[ "$#" -eq 0 ]] || cmd+=" -p '$*'"
        cmd+=" | grep -vFx 'Data collection is disabled.'"
    fi
    eval "$cmd" 2>/dev/null
elif [[ -x "$(command -v amp)" ]]; then
    if [[ -t 0 ]]; then
        echo "$*" | amp
    else
        cat | amp
    fi | grep -vE -e '^>(\s|$)' -e '^Thread ID:' | perl -000 -lnE 'say "$_\n"'
elif [[ -x "$(command -v cody)" ]]; then
    markdown='auto'

    args=$(getopt --name="$0" --options 'f:m' --longoptions 'file:,markdown' -- "$@")
    eval set -- "$args"

    chat_args=(--silent)

    while ((1)); do
        case "$1" in
            -f | --file) chat_args+=(--context-file="$2"); shift 2 ;;
            -m | --markdown) markdown="always"; shift ;;
            --) shift; break ;;
        esac
    done

    if [[ -t 0 ]]; then
        cody chat "${chat_args[@]}" -m "$*" 2>/dev/null
    else
        cody chat "${chat_args[@]}" --stdin 2>/dev/null
    fi \
        | if [[ "$markdown" == "always" ]] || [[ "$markdown" == "auto" && -t 1 ]]; then
        glow -p
    else
        cat
    fi
else
    # if [[ -x "$(command -v ollama)" ]] && ollama ps | grep 'codellama' &>/dev/null; then
    #   cat | { lines-join; echo; } | tee -a /dev/stderr | ollama run codellama
    #   exit
    # fi
    :
fi

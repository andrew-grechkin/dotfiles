#!/usr/bin/env zsh

# man: zshexpn

set -Euo pipefail

if [[ "$#" -eq "1" ]] && [[ "$1" =~ .git$ ]]; then
	REPO=$(dirname "$1")

    echo -n "$(tput setaf 3)"
	echo "Updating $REPO"
    echo -n "$(tput sgr0)"
	# echo -e '\033[0;33m'"Updating $REPO"'\033[0m'

	nice git -C "$REPO" fetch --all -p \
		&& nice git -C "$REPO" pull
else
	setopt globdots

	PWD=${1:-$PWD}
	GIT_DIRS=("$PWD"/**/.git)

	for DIR in "$PWD"/*(@N); do
		GIT_DIR="$DIR/.git"

		[[ -d "$GIT_DIR" ]] && GIT_DIRS+=("$GIT_DIR")
	done

	if [[ -n "$(command -v parallel)" ]]; then
		parallel -k -j-2 "$0" {} ::: "${(ou)GIT_DIRS[@]}"
	else
		for GIT_DIR in "${(ou)GIT_DIRS[@]}"; do
			"$0" "$GIT_DIR"
		done
	fi
fi

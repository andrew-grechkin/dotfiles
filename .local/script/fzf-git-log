#!/usr/bin/env bash

set -Eeo pipefail

CMD=(
	fzf
	--ansi
	--no-multi
	--no-sort
	--reverse
	--scheme=history
	--scroll-off=8
	--track
	--bind="ctrl-y:execute-silent(echo -n {1} | clipcopy)"
	--bind='tab:accept,shift-tab:accept'
	--header='Press C-v to preview, C-o to checkout, C-m/enter to show fullscreen'
)

OPTIONS=("$@")
for i in ${!OPTIONS[*]}; do
	OPTION="${OPTIONS[$i]}"
	if [[ "$OPTION" =~ --reload-command= ]]; then
		CMD+=(
			--header='C-j/k:move C-m/enter:view A-p:preview C-n/p:p-move C-y:yank C-r:reload A-f:fetch A-g:pull A-m:co-m A-o:co A-b:browse'
			--bind="alt-f:execute-silent(git fall)+reload(${OPTION#--reload-command=})"
			--bind="alt-g:execute-silent(git up)+reload(${OPTION#--reload-command=})"
			--bind="alt-m:execute-silent(ABB=\$(git gmb); git switch \$ABB)+reload(${OPTION#--reload-command=})"
			--bind="alt-o:execute-silent(A=\$(git describe --all --always {1}); git switch --detach \${A/heads\/})+reload(${OPTION#--reload-command=})"
			--bind="ctrl-r:reload(${OPTION#--reload-command=})"
		)
		unset "OPTIONS[$i]"
	fi
done

if [[ -n "$(command -v delta)"  ]]; then
	LOG_PAGER="delta"
else
	LOG_PAGER="$PAGER"
fi

CMD+=(
	--bind="alt-b:execute-silent(git browse {1})"
	--bind="ctrl-m:execute(show-commit {1} ${OPTIONS[@]} | $LOG_PAGER)"
	--preview="show-commit {1} --color=always ${OPTIONS[@]} | $LOG_PAGER"
)

exec "${CMD[@]}"

#!/usr/bin/env bash

set -Eeo pipefail

COMMAND_EXTRACT_COMMIT="echo {} | grep -o '[[:xdigit:]]\{6,\}' | head -1 | tr -d '\n'"

CMD=(
	fzf
	--ansi
	--no-multi
	--no-sort
	--reverse
	--scheme=history
	--scroll-off=8
	--tabstop=4
	--tiebreak=index
	--track
	--preview-window=right:60%:border-left:wrap:hidden
	--bind='ctrl-d:page-down,ctrl-u:page-up'
	--bind='ctrl-h:preview-up,ctrl-l:preview-down'
	--bind='ctrl-v:toggle-preview,ctrl-w:toggle-preview-wrap,ctrl-s:toggle-sort'
	--bind="ctrl-y:execute-silent(${COMMAND_EXTRACT_COMMIT} | clipcopy)"
	--bind='esc:cancel'
	--bind='home:top'
	--bind='tab:accept,shift-tab:accept'
	--header='Press C-v to preview, C-o to checkout, C-m/enter to show fullscreen'
)

OPTIONS=("$@")
for i in ${!OPTIONS[*]}; do
	OPTION="${OPTIONS[$i]}"
	if [[ "$OPTION" =~ --reload-command= ]]; then
		CMD+=(
			--header='Keys: move(C-j/k), preview(C-v), p-move(C-h/l), yank(C-y), (C-m/enter), fetch(C-f), pull(C-g), checkout(C-o), reload(C-r)'
			--bind="ctrl-f:execute-silent(git fall)+reload(${OPTION#--reload-command=})"
			--bind="ctrl-g:execute-silent(git up)+reload(${OPTION#--reload-command=})"
			--bind="ctrl-o:execute-silent(C=\$(${COMMAND_EXTRACT_COMMIT}); A=\$(git describe --all --always \$C); git checkout \${A/heads\/})+reload(${OPTION#--reload-command=})"
			--bind="ctrl-t:execute-silent(ABB=\$(git gmb); git checkout \$ABB)+reload(${OPTION#--reload-command=})"
			--bind="ctrl-r:reload(${OPTION#--reload-command=})"
		)
		unset "OPTIONS[$i]"
	fi
done

CMD+=(
	--bind="ctrl-m:execute(show-commit \"\$(${COMMAND_EXTRACT_COMMIT})\" ${OPTIONS[@]} | $PAGER)"
	--preview="show-commit \"\$(${COMMAND_EXTRACT_COMMIT})\" --color=always ${OPTIONS[@]}"
)

exec "${CMD[@]}"

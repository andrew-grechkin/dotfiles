#!/usr/bin/env bash

set -Eeo pipefail

COMMAND_EXTRACT_COMMIT="echo {} | grep -o '[[:xdigit:]]\{6,\}' | head -1 | tr -d '\n'"

CMD=(
	fzf
	--ansi
	--no-multi
	--no-sort
	--reverse
	--scheme=history
	--scroll-off=8
	--tabstop=4
	--track
	--bind="ctrl-y:execute-silent(${COMMAND_EXTRACT_COMMIT} | clipcopy)"
	--bind='tab:accept,shift-tab:accept'
	--header='Press C-v to preview, C-o to checkout, C-m/enter to show fullscreen'
)

OPTIONS=("$@")
for i in ${!OPTIONS[*]}; do
	OPTION="${OPTIONS[$i]}"
	if [[ "$OPTION" =~ --reload-command= ]]; then
		CMD+=(
			--header='move(C-j/k), view(C-m/enter), preview(C-v), p-move(C-n/p), yank(C-y), fetch(A-f), pull(A-g), browse(A-b), co(C-o), co-main(C-t), reload(C-r)'
			--bind="alt-f:execute-silent(git fall)+reload(${OPTION#--reload-command=})"
			--bind="alt-g:execute-silent(git up)+reload(${OPTION#--reload-command=})"
			--bind="ctrl-o:execute-silent(C=\$(${COMMAND_EXTRACT_COMMIT}); A=\$(git describe --all --always \$C); git checkout \${A/heads\/})+reload(${OPTION#--reload-command=})"
			--bind="ctrl-t:execute-silent(ABB=\$(git gmb); git checkout \$ABB)+reload(${OPTION#--reload-command=})"
			--bind="ctrl-r:reload(${OPTION#--reload-command=})"
		)
		unset "OPTIONS[$i]"
	fi
done

CMD+=(
	--bind="ctrl-m:execute(show-commit \"\$(${COMMAND_EXTRACT_COMMIT})\" ${OPTIONS[@]} | $PAGER)"
	--bind="alt-b:execute(git browse \"\$(${COMMAND_EXTRACT_COMMIT})\")"
	--preview="show-commit \"\$(${COMMAND_EXTRACT_COMMIT})\" --color=always ${OPTIONS[@]}"
)

exec "${CMD[@]}"

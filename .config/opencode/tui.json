{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "command_list": "ctrl+o",
    "history_next": "down,ctrl+j",
    "history_previous": "up,ctrl+k",
    "input_delete_to_line_end": "none",
    "input_newline": "shift+return,ctrl+return",
    "messages_half_page_down": "ctrl+n",
    "messages_half_page_up": "ctrl+p",
    "messages_line_down": "ctrl+j",
    "messages_line_up": "ctrl+k"
  }
}

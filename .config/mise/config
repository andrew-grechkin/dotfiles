# vim: filetype=toml

[tools]
argc = "latest"
bats = "latest"
delta = "latest"
deno = "latest"
eza = "latest"
fzf = "latest"
jq = "latest"
neovim = "latest"
oauth2c = "latest"
rg = "latest"
tree-sitter = "latest"
usage = "latest"
uv = "latest"
yamllint = "latest"
yq = "latest"

[tools.bat]
postinstall = '''
    umask 022
    mkdir -p $XDG_DATA_HOME/completion $XDG_DATA_HOME/man/man1
    ln -fs $MISE_TOOL_INSTALL_PATH/**/autocomplete/bat.zsh $XDG_DATA_HOME/completion/_bat
    ln -fs $MISE_TOOL_INSTALL_PATH/**/*.1 $XDG_DATA_HOME/man/man1
'''
version = "latest"

[tools.fd]
postinstall = '''
    umask 022
    mkdir -p $XDG_DATA_HOME/completion $XDG_DATA_HOME/man/man1
    ln -fs $MISE_TOOL_INSTALL_PATH/**/autocomplete/_* $XDG_DATA_HOME/completion
    ln -fs $MISE_TOOL_INSTALL_PATH/**/*.1 $XDG_DATA_HOME/man/man1
'''
version = "latest"

[tools.gum]
postinstall = '''
    umask 022
    mkdir -p $XDG_DATA_HOME/completion $XDG_DATA_HOME/man/man1
    ln -fs $MISE_TOOL_INSTALL_PATH/**/completions/gum.zsh $XDG_DATA_HOME/completion/_gum
    ln -fs $MISE_TOOL_INSTALL_PATH/**/manpages/*.1.gz $XDG_DATA_HOME/man/man1
'''
version = "latest"

[tools.hurl]
postinstall = '''
    umask 022
    mkdir -p $XDG_DATA_HOME/completion $XDG_DATA_HOME/man/man1
    ln -fs $MISE_TOOL_INSTALL_PATH/**/completions/_hurl* $XDG_DATA_HOME/completion
'''
version = "latest"

[tools.hwatch]
postinstall = '''
    umask 022
    mkdir -p $XDG_DATA_HOME/completion $XDG_DATA_HOME/man/man1
    ln -fs $MISE_TOOL_INSTALL_PATH/**/completion/zsh/* $XDG_DATA_HOME/completion
    ln -fs $MISE_TOOL_INSTALL_PATH/**/man/* $XDG_DATA_HOME/man/man1
'''
version = "latest"

[tools.just]
postinstall = '''
    umask 022
    mkdir -p $XDG_DATA_HOME/completion $XDG_DATA_HOME/man/man1
    ln -fs $MISE_TOOL_INSTALL_PATH/**/completions/just.zsh $XDG_DATA_HOME/completion/_just
    ln -fs $MISE_TOOL_INSTALL_PATH/**/*.1 $XDG_DATA_HOME/man/man1
'''
version = "latest"

[tools.node]
postinstall = '''
    exec >&2
    umask 022
    echo "> installing global NPM modules"
    npm install -g neovim pnpm yarn
'''
version = "24.14.1"

[tools.perl]
postinstall = '''
    exec >&2
    umask 022
    echo "> installing perl modules from: $HOME/.local/lib"
    # source mise-perl-global.rc

    cd $HOME/.local/lib
    unset PERL_LOCAL_LIB_ROOT
    unset PERL_MB_OPT
    unset PERL_MM_OPT
    export PERL_CPANM_HOME="${PERL_CPANM_HOME:-${XDG_CACHE_HOME:-$HOME/.cache}/cpanm}"

    cpanm -fnq "https://github.com/andrew-grechkin/DateTime-TimeZone-Zoneinfo/archive/refs/heads/main.tar.gz"
    cpanm -fnq "https://github.com/andrew-grechkin/yaml-libyaml-pm/archive/refs/heads/master.tar.gz"
    cpanm -nq --installdeps . 2>&1 | grep --line-buffered -Ev 'LIBARCHIVE[.]xattr[.]com[.](apple|macromates)'
'''
version = "5.42.2.0"

[tools.ruby]
postinstall = '''
    exec >&2
    umask 022
    echo "> installing ruby gems"
    gem update --system
    gem install neovim
    gem install rails
'''
version = "4.0.2"

[tools.step]
postinstall = '''
    umask 022
    mkdir -p $XDG_DATA_HOME/completion $XDG_DATA_HOME/man/man1
    ln -fs $MISE_TOOL_INSTALL_PATH/**/autocomplete/zsh_autocomplete $XDG_DATA_HOME/completion/_step
'''
version = "latest"

[tools.xh]
postinstall = '''
    umask 022
    mkdir -p $XDG_DATA_HOME/completion $XDG_DATA_HOME/man/man1
    ln -fs $MISE_TOOL_INSTALL_PATH/**/completions/_xh $XDG_DATA_HOME/completion/
    ln -fs $MISE_TOOL_INSTALL_PATH/**/doc/*.1 $XDG_DATA_HOME/man/man1
'''
version = "latest"

[settings]
idiomatic_version_file_enable_tools = ["ruby"]

# [settings.gitnub]
# use_git_credentials = true

[settings.ruby]
compile = true

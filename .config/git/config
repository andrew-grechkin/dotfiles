[alias]
	b          = branch -vv
	bleach     = !"f(){ git fall; git b | perl -alE 'm/: gone]/ && $F[0] ne \"*\" && system(qq(git branch -D $F[0]))'; }; f"
	bmain      = !"git rev-parse --abbrev-ref origin/HEAD 2>&1 | grep -Eho 'main$|trunk$|master$'"
	bname      = !"git rev-parse --abbrev-ref HEAD"
	bredo      = !"git rebase -i `git merge-base master HEAD`"
	bush       = !"f(){ while true; do git push && break; git pull --no-tags --rebase || break; done }; f"
	cl         = clone --filter=blob:none
	co         = checkout
	compress   = !"git-compress"
	compress-a = !"git-compress-aggressive"
	d          = diff -b
	dc         = diff -b --cached
	dg         = difftool --gui
	ds         = diff -b --submodule=diff
	dt         = difftool
	fall       = fetch --all --prune --prune-tags
	ha         = !"git --no-pager log --all --graph --pretty=oneline"
	l          = !"fzf-git-log-branch"
	la         = !"fzf-git-log-all"
	lag        = !"fzf-git-log-all-graph"
	lg         = !"fzf-git-log-graph"
	lr         = !"fzf-git-reflog"
	m-diff     = !"f(){ git diff     -b  --color=always `git m-span ... $@`; }; f"
	m-dt       = !"f(){ git difftool -b -t vimdiff      `git m-span ... $@`; }; f"
	m-log      = !"f(){ git log          --color=always `git m-span ..  $@`; }; f"
	m-span     = !"f(){ C=${2-\"$(git bname)\"}; A=$(git log -1 $C --merges --pretty=format:%P); echo ${A/ /$1}; }; f"
	main       = !"git checkout $(git bmain)"
	mg         = mergetool --gui
	mt         = mergetool
	pall       = !"git-push-all"
	pub        = !"git push -u origin $(git bname) -o merge_request.create -o merge_request.remove_source_branch"
	puba       = !"git push -u origin $(git bname) -o merge_request.create -o merge_request.remove_source_branch -o merge_request.merge_when_pipeline_succeeds"
	root       = rev-parse --show-toplevel
	rv         = !"git diff -b --color=always $(git merge-base $(git bmain) HEAD 2>/dev/null)...HEAD"
	rv-dt      = !"git difftool -b -t vimdiff $(git merge-base $(git bmain) HEAD 2>/dev/null)...HEAD"
	sh         = !"show-commit | $PAGER -r"
	st         = status -b
	unpub      = !"git push origin :$(git bname)"
	untag      = !"git push origin :$(git describe --exact-match --tags)"
	up         = pull --no-tags
	what       = whatchanged --show-signature

[apply]
	whitespace = fix

[color]
	branch      = auto
	diff        = auto
	grep        = auto
	interactive = auto
	showbranch  = auto
	status      = auto
	ui          = auto

[commit]
	verbose = true

[core]
	autocrlf     = false
	editor       = vim
	longpaths    = true
	pager        = less -x4 -i
	preloadindex = true
	quotepath    = false
	tabwidth     = 4
	whitespace   = trailing-space,space-before-tab,blank-at-eol,blank-at-eof,cr-at-eol

;[credential]
;	helper = /usr/lib/git-core/git-credential-libsecret

[diff]
	tool            = fugitive
	guitool         = meld
	algorithm       = patience
	colorMoved      = plain
	colorMovedWS    = ignore-space-change
	indentHeuristic = true
;	diff-algorithm  = patience
;	submodule       = diff

[difftool]
	prompt        = false
	trustExitCode = true                                                       # Be able to abort all diffs with ':cq' or ':cquit'

[difftool "fugitive"]
	cmd = vim -f -c "Gdiffsplit!" "$MERGED"

[difftool "vimdiff"]
	cmd = vimdiff "$LOCAL" "$REMOTE"

[difftool "meld"]
	cmd = meld "$LOCAL" "$REMOTE"

[fetch]
	prune = true

[gc]
	auto = 0

[grep]
	extendedRegexp = true
	lineNumber     = true

[gui]
	encoding = utf-8

[init]
	defaultBranch = master

[help]
	autocorrect = 1

[http]
	sslVerify = true

[log]
	color    = auto
	date     = iso
	decorate = short

[merge]
	tool          = fugitive
	guitool       = meld
	conflictstyle = diff3

[mergetool]
	keepBackup    = false
	prompt        = false
	trustExitCode = true

[mergetool "fugitive"]
	cmd = vim -f -c "Gdiffsplit!" "$MERGED"

[mergetool "meld"]
	cmd = meld "$LOCAL" "$BASE" "$REMOTE" --output "$MERGED"

[mergetool "nvimdiff4"]
	cmd = nvim -d "$LOCAL" "$BASE" "$REMOTE" "$MERGED" -c '$wincmd w' -c 'wincmd J'

[pager]
	branch = false

[pull]
	rebase = true

[push]
	default = simple

[rebase]
	autosquash = true
	autostash  = true

[tag]
	sort = version:refname

;[url "https://"]
;	insteadOf = git://

[include]
	path = ~/.config/gitconfig.overrides

[alias]
	bleach   = !"f(){ git fall; git br | awk '/: gone]/{print $1}' | xargs --no-run-if-empty git branch -d; }; f"
	br       = branch -vv
	br-name  = !"git rev-parse --abbrev-ref HEAD"
	br-redo  = !"git rebase -i `git merge-base master HEAD`"
	bush     = !"f(){ while true; do git push && break; git pull --no-tags --rebase || break; done }; f"
	co       = checkout
	compress = !"git-compress"
	d        = diff -b
	dc       = diff -b --cached
	ds       = diff -b --submodule=diff
	dt       = difftool
	dg       = difftool --gui
	fall     = fetch --all --prune --prune-tags
	ha       = !"git --no-pager log --all --graph --pretty=oneline"
	l        = !"fzf-git-log-branch"
	lr       = !"fzf-git-reflog"
	lg       = !"fzf-git-log-graph"
	la       = !"fzf-git-log-all"
	lag      = !"fzf-git-log-all-graph"
	main     = !"git rev-parse --abbrev-ref origin/HEAD 2>&1 | grep -Eho 'origin/trunk|origin/master'"
	master   = !"git checkout $(git rev-parse --abbrev-ref origin/HEAD 2>&1 | grep -Eho 'trunk|master')"
	mt       = mergetool
	mg       = mergetool --gui
	pall     = !"git-push-all"
	rv       = !"git diff -b --color=always $(git merge-base $(git main) HEAD 2>/dev/null)...HEAD"
	rv-dt    = !"git difftool -b -t vimdiff $(git merge-base $(git main) HEAD 2>/dev/null)...HEAD"
	sh       = show --show-signature -b
	st       = status -b
	up       = pull --no-tags
	what     = whatchanged --show-signature
	pub      = !"git push -u origin $(git br-name) -o merge_request.create -o merge_request.remove_source_branch"
	unpub    = !"git push origin :$(git br-name)"
	unpubt   = !"git push origin :$(git describe --exact-match --tags)"
	m-span   = !"f(){ C=${2-\"$(git br-name)\"}; A=$(git log -1 $C --merges --pretty=format:%P); echo ${A/ /$1}; }; f"
	m-log    = !"f(){ git log          --color=always `git m-span ..  $@`; }; f"
	m-diff   = !"f(){ git diff     -b  --color=always `git m-span ... $@`; }; f"
	m-dt     = !"f(){ git difftool -b -t vimdiff      `git m-span ... $@`; }; f"

[apply]
	whitespace = fix

[color]
	branch      = auto
	diff        = auto
	grep        = auto
	interactive = auto
	showbranch  = auto
	status      = auto
	ui          = auto

[commit]
	verbose = true

[core]
	autocrlf     = false
	editor       = vim
	longpaths    = true
	pager        = less -x4 -i
	preloadindex = true
	quotepath    = false
	tabwidth     = 4
	whitespace   = trailing-space,space-before-tab,blank-at-eol,blank-at-eof,cr-at-eol

;[credential]
;	helper = /usr/lib/git-core/git-credential-libsecret

[diff]
	tool            = fugitive
	guitool         = meld
	algorithm       = patience
	colorMoved      = plain
	colorMovedWS    = ignore-space-change
	indentHeuristic = true
;	diff-algorithm  = patience
;	submodule       = diff

[difftool]
	prompt        = false
	trustExitCode = true                                                       # Be able to abort all diffs with ':cq' or ':cquit'

[difftool "fugitive"]
	cmd = vim -f -c "Gdiffsplit!" "$MERGED"

[difftool "vimdiff"]
	cmd = vimdiff "$LOCAL" "$REMOTE"

[difftool "meld"]
	cmd = meld "$LOCAL" "$REMOTE"

[fetch]
	prune = true

[grep]
	extendedRegexp = true
	lineNumber     = true

[gui]
	encoding = utf-8

[help]
	autocorrect = 1

[http]
	sslVerify = true

[log]
	color    = auto
	date     = iso
	decorate = short

[merge]
	tool          = fugitive
	guitool       = meld
	conflictstyle = diff3

[mergetool]
	keepBackup    = false
	prompt        = false
	trustExitCode = true

[mergetool "fugitive"]
	cmd = vim -f -c "Gdiffsplit!" "$MERGED"

[mergetool "meld"]
	cmd = meld "$LOCAL" "$BASE" "$REMOTE" --output "$MERGED"

[mergetool "nvimdiff4"]
	cmd = nvim -d "$LOCAL" "$BASE" "$REMOTE" "$MERGED" -c '$wincmd w' -c 'wincmd J'

[pager]
	branch = false

[pull]
	rebase = true

[push]
	default = simple

[rebase]
	autosquash = true
	autostash  = true

[tag]
	sort = version:refname

;[url "https://"]
;	insteadOf = git://

[include]
	path = ~/.config/gitconfig.overrides

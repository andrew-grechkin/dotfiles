[alias]
	br       = branch -vv
	bush     = !"f(){while true; do git push && break; git pull --no-tags --rebase || break; done}; f"
	co       = checkout
	compress = !"zsh -c 'gcompress'"
	d        = diff -b --submodule=diff
	dg       = difftool --gui
	dt       = difftool
	fall     = fetch --all --prune --prune-tags
	ha       = !git --no-pager log --all --graph --pretty=oneline
	l        = !"zsh -c 'glo'"
	lr       = !"zsh -c 'glor'"
	lg       = !"zsh -c 'glog'"
	la       = !"zsh -c 'gla'"
	lag      = !"zsh -c 'glag'"
	mg       = mergetool --gui
	mt       = mergetool
	pall     = !"zsh -c 'gpall'"
	pushallf = !"zsh -c 'gpushallf'"
	sh       = show --show-signature -b
	st       = status -b
	up       = pull -v --no-tags
	w        = whatchanged --show-signature

[apply]
	whitespace = fix

[color]
	branch      = auto
	diff        = auto
	grep        = auto
	interactive = auto
	showbranch  = auto
	status      = auto
	ui          = auto

[commit]
	verbose = true

[core]
	autocrlf     = false
	editor       = vim
	longpaths    = true
	pager        = less -x4 -i
	preloadindex = true
	quotepath    = false
	tabwidth     = 4
	whitespace   = trailing-space,space-before-tab,blank-at-eol,blank-at-eof,cr-at-eol

;[credential]
;	helper = /usr/lib/git-core/git-credential-libsecret

[diff]
	tool            = fugitive
	guitool         = meld
	algorithm       = patience
	colorMoved      = plain
	colorMovedWS    = ignore-space-change
	indentHeuristic = true
;	diff-algorithm  = patience
;	submodule       = diff

[difftool]
	prompt        = false
	trustExitCode = true                                                       # Be able to abort all diffs with ':cq' or ':cquit'

[difftool "fugitive"]
	cmd = vim -f -c "Gdiffsplit!" "$MERGED"

[difftool "meld"]
	cmd = meld "$LOCAL" "$REMOTE"

[fetch]
	prune = true

[grep]
	extendedRegexp = true
	lineNumber     = true

[gui]
	encoding = utf-8

[help]
	autocorrect = 1

[http]
	sslVerify = true

[log]
	color    = auto
	date     = iso
	decorate = short

[merge]
	tool          = fugitive
	guitool       = meld
	conflictstyle = diff3

[mergetool]
	keepBackup    = false
	prompt        = false
	trustExitCode = true

[mergetool "fugitive"]
	cmd = vim -f -c "Gdiffsplit!" "$MERGED"

[mergetool "meld"]
	cmd = meld "$LOCAL" "$BASE" "$REMOTE" --output "$MERGED"

[mergetool "nvimdiff4"]
	cmd = nvim -d "$LOCAL" "$BASE" "$REMOTE" "$MERGED" -c '$wincmd w' -c 'wincmd J'

[pager]
	branch = false

[pull]
	rebase = true

[push]
	default = simple

[rebase]
	autosquash = true
	autostash  = true

[tag]
	sort = version:refname

;[url "https://"]
;	insteadOf = git://

[include]
	path = ~/.config/gitconfig.overrides

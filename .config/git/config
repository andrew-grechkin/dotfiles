[alias]
	aa           = add --all
	b            = branch -vv
	behind       = !"MAIN_UBRANCH=\"$(git mu)\"; echo \"Behind $MAIN_UBRANCH:\" &>/dev/stderr; git log --oneline \"HEAD..$MAIN_UBRANCH\" | wc -l"
	bleach       = !"f(){ git fall; git b | perl -alE 'm/: gone]/ && $F[0] ne q(*) && system(qq(git branch -D $F[0]))'; }; f"
	bname        = rev-parse --abbrev-ref HEAD
	branches     = !"git branch --list --no-column --format='%(refname:lstrip=2)' \"$@\""
	bredo        = !"f(){ git rebase -i --keep-base --committer-date-is-author-date `git mb $@`; }; f"
	bush         = !"f(){ while true; do git push && break; git pull --no-tags --rebase || break; done }; f"
	cl           = clone --filter=blob:none
	co           = checkout
	commit-again = !"git commit -eF \"$(git root)/.git/COMMIT_EDITMSG\""
	compress     = !"git-compress"
	compress-a   = !"git-compress-aggressive"
	d            = diff -b
	dc           = diff -b --cached
	dg           = difftool --gui
	ds           = diff -b --submodule=diff
	dt           = difftool
	dtw          = !"git difftool -b -t vimdiff $(git mb)..HEAD"
	dw           = !"git diff -b --color=always $(git mb)..HEAD"
	fall         = fetch --all --prune --prune-tags
	ha           = !"git --no-pager log --abbrev-commit --all --color=always --graph --pretty=oneline --topo-order"
	l            = !"fzf-git-log-branch"
	la           = !"fzf-git-log-all"
	lag          = !"fzf-git-log-all-graph"
	lg           = !"fzf-git-log-branch-graph"
	lr           = !"git-log-reflog-graph"
	lw           = !"fzf-git-log-branch $(git mu)..HEAD"
	m            = !"git checkout `git mb`"
	m-base       = !"f(){ git merge-base ${1:-$(git mb)} HEAD; }; f"
	m-diff       = !"f(){ git diff     -b  --color=always `git m-span .. $@`; }; f"
	m-dt         = !"f(){ git difftool -b -t vimdiff      `git m-span .. $@`; }; f"
	m-log        = !"f(){ git log          --color=always `git m-span .. $@`; }; f"
	m-span       = !"git-merge-span"
	mb           = !"MAIN_REMOTE=\"$(git mr)\"; [[ -n \"$MAIN_REMOTE\" ]] && { git mu | grep -Po \"(?<=$MAIN_REMOTE/)\\w+$\"; } || git rev-parse --abbrev-ref --symbolic-full-name HEAD"
	mg           = mergetool --gui
	mr           = !"git branch --list --no-column --all | grep -Po '(?<=remotes/)\\w+(?=/HEAD)'"
	mt           = mergetool
	mu           = !"MAIN_REMOTE=\"$(git mr)\"; git rev-parse --abbrev-ref \"$MAIN_REMOTE/HEAD\" 2>&1"
	pall         = !"git-push-all"
	pub          = !"git push -u origin $(git bname) -o merge_request.create -o merge_request.remove_source_branch"
	puba         = !"git push -u origin $(git bname) -o merge_request.create -o merge_request.remove_source_branch -o merge_request.merge_when_pipeline_succeeds"
	root         = rev-parse --show-toplevel
	sh           = !"show-commit $@"
	; sh         = !"show-commit $@ | $PAGER -r"
	st           = status -b
	u            = rev-parse --abbrev-ref --symbolic-full-name @{upstream}
	unpub        = !"git push origin :$(git bname)"
	untag        = !"git push origin :$(git describe --exact-match --tags)"
	up           = pull --no-tags
	what         = whatchanged --show-signature

[apply]
	whitespace = fix

[color]
	branch      = auto
	diff        = auto
	grep        = auto
	interactive = auto
	showbranch  = auto
	status      = auto
	ui          = auto

[core]
	autocrlf     = false
	editor       = vim
	longpaths    = true
	pager        = less -x4 -i
	preloadindex = true
	quotepath    = false
	tabwidth     = 4
	whitespace   = trailing-space,space-before-tab,blank-at-eol,blank-at-eof,cr-at-eol

;[credential]
;	helper = /usr/lib/git-core/git-credential-libsecret

[diff]
	tool            = fugitive
	guitool         = kompare
	algorithm       = patience
	colorMoved      = plain
	colorMovedWS    = ignore-space-change
	indentHeuristic = true
;	diff-algorithm  = patience
;	submodule       = diff

[difftool]
	prompt        = false
	trustExitCode = true                                                       # be able to abort all diffs with ':cq' or ':cquit'

[difftool "fugitive"]
	cmd = vim -f -c "Gdiffsplit!" "$MERGED"

[difftool "vimdiff"]
	cmd = vimdiff "$LOCAL" "$REMOTE"

[difftool "meld"]
	cmd = meld "$LOCAL" "$REMOTE"

[fetch]
	prune = true

[format]
	pretty = commit %H%d %(describe:tags) %nAuthor:     %aN <%aE>%nAuthorDate: %ai%nCommit:     %cN <%cE>%nCommitDate: %ci%n%n%B

[gc]
	auto = 0

[grep]
	extendedRegexp = true
	lineNumber     = true

[gui]
	encoding = utf-8

[init]
	defaultBranch = main
	templatedir = ~/.config/git/init-template

[help]
	autocorrect = 1

[http]
	sslVerify = true

[log]
	color    = auto
	date     = iso8601
	decorate = short

[merge]
	tool          = fugitive
	guitool       = kompare
	conflictstyle = diff3

[mergetool]
	keepBackup    = false
	prompt        = false
	trustExitCode = true

[mergetool "fugitive"]
	cmd = vim -f -c "Gdiffsplit!" "$MERGED"

[mergetool "meld"]
	cmd = meld "$LOCAL" "$BASE" "$REMOTE" --output "$MERGED"

[mergetool "nvimdiff4"]
	cmd = nvim -d "$LOCAL" "$BASE" "$REMOTE" "$MERGED" -c '$wincmd w' -c 'wincmd J'

[pager]
	branch = false
	diff   = delta
	log    = delta
	reflog = delta
	sh     = delta
	show   = delta

[pull]
	rebase = true

[rebase]
	abbreviateCommands  = true
	autoSquash          = true
	autoStash           = true
	missingCommitsCheck = warn
	stat                = true
	updateRefs          = true

[rerere]
	enabled = true

[tag]
	sort = version:refname

[include]
	path = ~/.config/gitconfig.overrides
	path = ~/.config/git/delta.gitconfig

# vim: syntax=zsh foldmethod=marker

# => Automatically start tmux on ssh connection. Logout on detach ------------------------------------------------ {{{1

if [[ -z "$TMUX" ]] && ! [[ ${SSH_CLIENT} =~ "::1" ]] && ! [[ ${SSH_CLIENT} =~ "127.0.0" ]]; then
	command tmux has-session &> /dev/null
	if [[ $? -eq 1 ]]; then
		tmux new
	else
		tmux attach
	fi
	exit
fi

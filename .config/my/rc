# vim: syntax=zsh foldmethod=marker

export                 LANG=${LANG:-en_US.utf8}
export                 LESS='-x4 -iRSw'
export         LESSHISTFILE=-

# => gnupg ------------------------------------------------------------------------------------------------------- {{{1

#if [[ -e "$HOME/.gnupg" ]]; then
